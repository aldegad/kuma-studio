{
  "name": "kuma-picker",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension and local daemon for visual UI selection bridging with coding agents.",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "kuma-pickerd:serve": "node ./packages/server/src/cli.mjs serve",
    "kuma-pickerd:get-selection": "node ./packages/server/src/cli.mjs get-selection",
    "kuma-pickerd:get-agent-note": "node ./packages/server/src/cli.mjs get-agent-note",
    "kuma-pickerd:get-extension-status": "node ./packages/server/src/cli.mjs get-extension-status",
    "kuma-pickerd:get-browser-session": "node ./packages/server/src/cli.mjs get-browser-session",
    "kuma-pickerd:browser-context": "node ./packages/server/src/cli.mjs browser-context",
    "kuma-pickerd:browser-dom": "node ./packages/server/src/cli.mjs browser-dom",
    "kuma-pickerd:browser-console": "node ./packages/server/src/cli.mjs browser-console",
    "kuma-pickerd:browser-debugger-capture": "node ./packages/server/src/cli.mjs browser-debugger-capture",
    "kuma-pickerd:browser-click": "node ./packages/server/src/cli.mjs browser-click",
    "kuma-pickerd:browser-sequence": "node ./packages/server/src/cli.mjs browser-sequence",
    "kuma-pickerd:browser-click-point": "node ./packages/server/src/cli.mjs browser-click-point",
    "kuma-pickerd:browser-fill": "node ./packages/server/src/cli.mjs browser-fill",
    "kuma-pickerd:browser-key": "node ./packages/server/src/cli.mjs browser-key",
    "kuma-pickerd:browser-refresh": "node ./packages/server/src/cli.mjs browser-refresh",
    "kuma-pickerd:browser-screenshot": "node ./packages/server/src/cli.mjs browser-screenshot",
    "kuma-pickerd:browser-wait-for-download": "node ./packages/server/src/cli.mjs browser-wait-for-download",
    "kuma-pickerd:browser-get-latest-download": "node ./packages/server/src/cli.mjs browser-get-latest-download",
    "kuma-pickerd:browser-wait-for-text": "node ./packages/server/src/cli.mjs browser-wait-for-text",
    "kuma-pickerd:browser-wait-for-text-disappear": "node ./packages/server/src/cli.mjs browser-wait-for-text-disappear",
    "kuma-pickerd:browser-wait-for-selector": "node ./packages/server/src/cli.mjs browser-wait-for-selector",
    "kuma-pickerd:browser-wait-for-dialog-close": "node ./packages/server/src/cli.mjs browser-wait-for-dialog-close",
    "kuma-pickerd:browser-query-dom": "node ./packages/server/src/cli.mjs browser-query-dom",
    "kuma-pickerd:set-agent-note": "node ./packages/server/src/cli.mjs set-agent-note",
    "kuma-pickerd:clear-agent-note": "node ./packages/server/src/cli.mjs clear-agent-note"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
