{
  "name": "kuma-studio",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent virtual office — browser automation bridge with visual dashboard and team characters",
  "repository": {
    "type": "git",
    "url": "https://github.com/aldegad/kuma-studio.git"
  },
  "homepage": "https://github.com/aldegad/kuma-studio",
  "bugs": {
    "url": "https://github.com/aldegad/kuma-studio/issues"
  },
  "keywords": [
    "ai-agents",
    "browser-automation",
    "dashboard",
    "virtual-office",
    "codex",
    "claude"
  ],
  "workspaces": [
    "packages/server",
    "packages/studio-web"
  ],
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "server:start": "node ./packages/server/src/cli.mjs serve --root .",
    "server:reload": "bash ./scripts/server-reload.sh",
    "kuma-server:reload": "bash ./scripts/bin/kuma-server-reload",
    "kuma-studio": "node ./packages/server/src/cli.mjs",
    "kuma-studio:get-selection": "node ./packages/server/src/cli.mjs get-selection",
    "kuma-studio:get-job-card": "node ./packages/server/src/cli.mjs get-job-card",
    "kuma-studio:get-extension-status": "node ./packages/server/src/cli.mjs get-extension-status",
    "kuma-studio:get-browser-session": "node ./packages/server/src/cli.mjs get-browser-session",
    "kuma-studio:run": "node ./packages/server/src/cli.mjs run",
    "kuma-studio:set-job-status": "node ./packages/server/src/cli.mjs set-job-status",
    "kuma-studio:vault-lint": "node ./packages/server/src/cli.mjs vault-lint",
    "kuma-studio:noeuri-watchdog": "bash ./scripts/cmux/kuma-cmux-noeuri-watchdog.sh",
    "vault:ingest": "node ./packages/server/src/cli.mjs vault-ingest",
    "kuma-studio:dashboard": "open http://localhost:4312/studio",
    "dev": "npm run server:reload",
    "build:studio": "npm run build --workspace=studio-web",
    "security:hooks:install": "bash ./scripts/security/install-hooks.sh",
    "security:scan": "bash ./scripts/security/run-gitleaks.sh --repo",
    "security:scan:staged": "bash ./scripts/security/run-gitleaks.sh --staged",
    "test": "vitest run --passWithNoTests",
    "skill:install": "node ./scripts/install.mjs",
    "skill:doctor": "node ./scripts/doctor.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
