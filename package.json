{
  "name": "kuma-picker",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension, local daemon, and bundled test web for visual UI selection bridging with coding agents.",
  "workspaces": [
    "example/next-host"
  ],
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=kuma-picker-example-next-host",
    "build:web": "npm run build --workspace=kuma-picker-example-next-host",
    "lint:web": "npm run lint --workspace=kuma-picker-example-next-host",
    "typecheck:web": "npm run typecheck --workspace=kuma-picker-example-next-host",
    "test": "vitest run --passWithNoTests",
    "kuma-pickerd:serve": "node ./packages/server/src/cli.mjs serve",
    "kuma-pickerd:get-selection": "node ./packages/server/src/cli.mjs get-selection",
    "kuma-pickerd:get-job-card": "node ./packages/server/src/cli.mjs get-job-card",
    "kuma-pickerd:get-extension-status": "node ./packages/server/src/cli.mjs get-extension-status",
    "kuma-pickerd:get-browser-session": "node ./packages/server/src/cli.mjs get-browser-session",
    "kuma-pickerd:run": "node ./packages/server/src/cli.mjs run",
    "kuma-pickerd:smoke": "node ./scripts/run-smoke-scenarios.mjs",
    "kuma-pickerd:measure": "node ./scripts/run-measurement-scenarios.mjs",
    "kuma-pickerd:parity:kuma": "node ./scripts/run-parity-scenarios.mjs --tool kuma --mode attach",
    "kuma-pickerd:parity:playwright": "node ./scripts/run-parity-scenarios.mjs --tool playwright --mode attach",
    "kuma-pickerd:parity:compare": "node ./scripts/compare-parity-results.mjs",
    "kuma-pickerd:set-job-status": "node ./packages/server/src/cli.mjs set-job-status",
    "skill:install": "node ./scripts/install.mjs",
    "skill:doctor": "node ./scripts/doctor.mjs"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
