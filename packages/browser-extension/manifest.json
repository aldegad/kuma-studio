{
  "manifest_version": 3,
  "name": "Kuma Picker Bridge",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "description": "Inspect the current webpage and send element or area picks to a local Kuma Picker daemon.",
  "permissions": [
    "activeTab",
    "contentSettings",
    "debugger",
    "downloads",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*",
    "wss://127.0.0.1/*",
    "wss://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icons/kuma-picker-icon-16.png",
    "32": "assets/icons/kuma-picker-icon-32.png",
    "48": "assets/icons/kuma-picker-icon-48.png",
    "128": "assets/icons/kuma-picker-icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kuma Picker Bridge",
    "default_icon": {
      "16": "assets/icons/kuma-picker-icon-16.png",
      "32": "assets/icons/kuma-picker-icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/runtime-observer-main.js",
        "assets/gestures/kuma-paw-tap.png",
        "assets/gestures/kuma-paw-grab.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/runtime-observer.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/constants.js",
        "content/page-context.js",
        "content/job-cards.js",
        "content/agent-actions-core.js",
        "content/agent-actions-gesture-overlay.js",
        "content/agent-actions-interaction.js",
        "content/agent-actions-observe-extra.js",
        "content/agent-actions-observe.js",
        "content/agent-actions.js",
        "content/bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
