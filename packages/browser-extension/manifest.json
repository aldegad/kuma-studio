{
  "manifest_version": 3,
  "name": "Agent Picker Bridge",
  "version": "0.1.0",
  "description": "Capture the current website into a local Agent Picker daemon.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agent Picker Bridge"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/constants.js",
        "content/page-context.js",
        "content/overlay-ui.js",
        "content/inspect-mode.js",
        "content/bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
