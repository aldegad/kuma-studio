{
  "name": "@agent-picker/example-next-host",
  "private": true,
  "scripts": {
    "agent-picker:prepare": "node ../../scripts/generate-agent-picker-drafts.mjs && node ../../scripts/sync-agent-picker-scene.mjs",
    "agent-picker:host-dev": "next dev --webpack",
    "predev": "node ../../scripts/run-package-script.mjs agent-picker:host-predev --optional && pnpm run agent-picker:prepare",
    "prebuild": "node ../../scripts/run-package-script.mjs agent-picker:host-prebuild --optional && pnpm run agent-picker:prepare",
    "build": "next build --webpack",
    "dev": "node ../../scripts/dev-agent-picker.mjs",
    "lint": "tsc --noEmit",
    "qa:agent-picker": "node ../../scripts/qa-agent-picker.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-picker/next": "workspace:*",
    "@agent-picker/picker": "workspace:*",
    "@agent-picker/workspace": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "0.577.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  }
}
