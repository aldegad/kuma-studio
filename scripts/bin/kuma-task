#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage: kuma-task <멤버이름> "<지시>" [--project <프로젝트>] [--qa <멤버|self|kuma-direct>] [--trust-worker]
       kuma-task decisions promote <inboxId> "<resolvedText>" [--context <ref>]

Options:
  --qa <멤버>        QA 담당 멤버 override. 우선순위는 --qa > member.defaultQa > KUMA_DEFAULT_QA_MEMBER > 밤토리
  --trust-worker     밤토리 QA를 생략하고 qa: worker-self-report 로 기록
  --no-qa            deprecated alias for --trust-worker
EOF
}

decisions_usage() {
  cat <<'EOF'
Usage: kuma-task decisions promote <inboxId> "<resolvedText>" [--context <ref>]
EOF
}

run_decisions_promote() {
  local inbox_id="${1:-}"
  local resolved_text="${2:-}"
  shift 2 || true

  [ -n "$inbox_id" ] || {
    decisions_usage >&2
    exit 1
  }
  [ -n "$resolved_text" ] || {
    decisions_usage >&2
    exit 1
  }

  local context_ref=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --context)
        context_ref="${2:?context required}"
        shift 2
        ;;
      -h|--help)
        decisions_usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  require_cmd node

  KUMA_REPO_ROOT="$KUMA_REPO_ROOT" \
  KUMA_DECISION_RUNTIME_ROOT="${KUMA_DECISION_RUNTIME_ROOT:-$KUMA_REPO_ROOT}" \
  KUMA_VAULT_DIR="$KUMA_VAULT_DIR" \
  node --input-type=module - "$inbox_id" "$resolved_text" "$context_ref" <<'NODE'
import { join, resolve } from "node:path";
import { pathToFileURL } from "node:url";

const [, , inboxIdRaw, resolvedTextRaw, contextRefRaw] = process.argv;
const inboxId = typeof inboxIdRaw === "string" ? inboxIdRaw.trim() : "";
const resolvedText = typeof resolvedTextRaw === "string" ? resolvedTextRaw.trim() : "";
const contextRef = typeof contextRefRaw === "string" ? contextRefRaw.trim() : "";
const repoRoot = process.env.KUMA_DECISION_RUNTIME_ROOT
  ? resolve(process.env.KUMA_DECISION_RUNTIME_ROOT)
  : process.env.KUMA_REPO_ROOT
    ? resolve(process.env.KUMA_REPO_ROOT)
    : process.cwd();
const vaultDir = process.env.KUMA_VAULT_DIR;

if (!inboxId) {
  throw new Error("inboxId is required");
}
if (!resolvedText) {
  throw new Error("resolvedText is required");
}
if (!vaultDir) {
  throw new Error("KUMA_VAULT_DIR is required");
}

const storeModule = await import(pathToFileURL(join(repoRoot, "packages/server/src/studio/decisions-store.mjs")).href);
if (typeof storeModule?.promoteToLedger !== "function") {
  throw new Error("decisions-store.promoteToLedger() is not available");
}

const result = await storeModule.promoteToLedger({
  vaultDir,
  inboxId,
  resolvedText,
  writer: "user-direct",
  contextRef,
});

process.stdout.write(`${JSON.stringify(result)}\n`);
NODE
}

run_decisions_command() {
  case "${1:-}" in
    promote)
      shift
      run_decisions_promote "$@"
      ;;
    -h|--help|"")
      decisions_usage
      ;;
    *)
      die "unknown decisions subcommand: $1"
      ;;
  esac
}

[ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
  usage
  exit 0
}

if [ "${1:-}" = "decisions" ]; then
  shift
  run_decisions_command "$@"
  exit $?
fi

[ $# -ge 2 ] || {
  usage >&2
  exit 1
}

MEMBER_QUERY="$1"
INSTRUCTION="$2"
shift 2

PROJECT="$(resolve_default_project || true)"
TRUST_WORKER=0
USED_DEPRECATED_NO_QA=0
QA_MEMBER_QUERY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT="${2:?project required}"
      shift 2
      ;;
    --qa)
      QA_MEMBER_QUERY="${2:?qa member required}"
      shift 2
      ;;
    --trust-worker)
      TRUST_WORKER=1
      shift
      ;;
    --no-qa)
      TRUST_WORKER=1
      USED_DEPRECATED_NO_QA=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

if [ "$TRUST_WORKER" = "1" ] && [ -n "$QA_MEMBER_QUERY" ]; then
  die "--qa and --trust-worker cannot be used together"
fi

if [ "$USED_DEPRECATED_NO_QA" = "1" ]; then
  printf '%s\n' "--no-qa is deprecated, use --trust-worker instead. This will still route through vault-auto-ingest." >&2
fi

ensure_runtime_requirements
require_file "$KUMA_CMUX_DIR/kuma-cmux-send.sh"
require_file "$KUMA_CMUX_DIR/kuma-cmux-read.sh"
mkdir -p "$KUMA_TASK_DIR" "$KUMA_RESULT_DIR"

MEMBER_JSON="$(resolve_member_json "$MEMBER_QUERY")" || die "unknown member: $MEMBER_QUERY"
MEMBER_NAME="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
MEMBER_ID="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.id);')"
MEMBER_TYPE="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.type);')"
MEMBER_DEFAULT_QA="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.defaultQa || "");')"

SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$MEMBER_JSON")" || die "surface not found for $MEMBER_NAME in project '$PROJECT'"
WORKER_SURFACE="$(printf '%s' "$SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
TEAM_STATUS_SNAPSHOT_JSON="$(read_team_status_snapshot_json "$PROJECT")"

read_project_member_status_json() {
  local snapshot_json="${1:?snapshot json required}"
  local member_id="${2:?member id required}"

  printf '%s' "$snapshot_json" | node -e '
    const fs = require("node:fs");
    const memberId = process.argv[1];
    const snapshot = JSON.parse(fs.readFileSync(0, "utf8"));
    const projects = Array.isArray(snapshot?.projects) ? snapshot.projects : [];
    for (const project of projects) {
      const members = Array.isArray(project?.members) ? project.members : [];
      const member = members.find((entry) => entry?.id === memberId);
      if (member) {
        process.stdout.write(`${JSON.stringify(member)}\n`);
        process.exit(0);
      }
    }
    process.stdout.write("{}\n");
  ' "$member_id"
}

member_status_field() {
  local member_status_json="${1:?member status json required}"
  local field="${2:?field required}"

  printf '%s' "$member_status_json" | node -e '
    const fs = require("node:fs");
    const data = JSON.parse(fs.readFileSync(0, "utf8"));
    const field = process.argv[1];
    let value = "";
    if (field === "preview") {
      value =
        (typeof data?.task === "string" && data.task.trim()) ||
        (Array.isArray(data?.lastOutputLines) && typeof data.lastOutputLines[0] === "string" ? data.lastOutputLines[0] : "") ||
        "";
    } else if (typeof data?.[field] === "string") {
      value = data[field];
    }
    process.stdout.write(`${value}\n`);
  ' "$field"
}

member_display_name_from_json() {
  local member_json="${1:?member json required}"

  printf '%s' "$member_json" | node -e '
    const fs = require("node:fs");
    const member = JSON.parse(fs.readFileSync(0, "utf8"));
    process.stdout.write(`${member.displayName || member.name || member.id || ""}\n`);
  '
}

member_id_from_json() {
  local member_json="${1:?member json required}"

  printf '%s' "$member_json" | node -e '
    const fs = require("node:fs");
    const member = JSON.parse(fs.readFileSync(0, "utf8"));
    process.stdout.write(`${member.id || ""}\n`);
  '
}

surface_id_from_json() {
  local surface_json="${1:?surface json required}"

  printf '%s' "$surface_json" | node -e '
    const fs = require("node:fs");
    const surface = JSON.parse(fs.readFileSync(0, "utf8"));
    process.stdout.write(`${surface.surface || ""}\n`);
  '
}

format_qa_candidate_summary() {
  local role="${1:-candidate}"
  local label="${2:-unknown}"
  local surface="${3:-}"
  local state="${4:-unknown}"
  local reason="${5:-}"
  local rendered_surface="${surface:--}"
  local rendered_state="${state:-unknown}"

  if [ -n "$reason" ]; then
    printf '%s %s (surface=%s, state=%s, reason=%s)' "$role" "$label" "$rendered_surface" "$rendered_state" "$reason"
  else
    printf '%s %s (surface=%s, state=%s)' "$role" "$label" "$rendered_surface" "$rendered_state"
  fi
}

spawn_member_surface_json() {
  local project="${1:?project required}"
  local member_json="${2:?member json required}"
  local context="${3:-auto-spawn}"
  local member_name=""
  local member_label=""
  local spawn_output=""
  local surface=""

  member_name="$(member_display_name_from_json "$member_json")"
  member_label="$(member_display_label_from_json "$member_json")"
  spawn_output="$("$SCRIPT_DIR/kuma-spawn" "$member_name" --project "$project" 2>&1)" || {
    printf 'QA_ROUTE_WARN: failed to auto-spawn %s (%s): %s\n' "$member_label" "$context" "$spawn_output" >&2
    return 1
  }

  surface="$(printf '%s\n' "$spawn_output" | awk -F': ' '/^SURFACE: /{print $2; exit}')"
  if [ -z "$surface" ]; then
    printf 'QA_ROUTE_WARN: auto-spawn for %s (%s) returned no SURFACE line\n' "$member_label" "$context" >&2
    return 1
  fi

  printf 'QA_ROUTE: %s -> auto-spawned %s (%s)\n' "$member_label" "$surface" "$context" >&2
  resolve_surface_json "$project" "$member_json"
}

dispatch_role_label() {
  case "${1:-}" in
    initiator)
      printf 'initiator'
      ;;
    worker)
      printf 'worker'
      ;;
    qa)
      printf 'QA'
      ;;
    surface)
      printf 'surface peer'
      ;;
    *)
      printf 'participant'
      ;;
  esac
}

resolve_surface_display_name() {
  local surface="${1:-}"
  local preferred_project="${2:-}"

  [ -n "$surface" ] || return 0

  node - "$KUMA_SURFACES_PATH" "$surface" "$preferred_project" <<'NODE'
const fs = require("node:fs");

const [, , registryPath, surfaceRaw, preferredProjectRaw] = process.argv;
const surface = typeof surfaceRaw === "string" ? surfaceRaw.trim() : "";
const preferredProject = typeof preferredProjectRaw === "string" ? preferredProjectRaw.trim() : "";
if (!surface || !registryPath || !fs.existsSync(registryPath)) {
  process.exit(0);
}

function normalize(value) {
  return typeof value === "string" ? value.trim() : "";
}

function parseRegistryLabel(label) {
  const text = normalize(label);
  const name = text.replace(/^[\p{Extended_Pictographic}\uFE0F\s]+/u, "").trim();
  return name || text;
}

const registry = JSON.parse(fs.readFileSync(registryPath, "utf8"));
const projectOrder = preferredProject
  ? [preferredProject, ...Object.keys(registry).filter((key) => key !== preferredProject)]
  : Object.keys(registry);

for (const projectId of projectOrder) {
  const entries = registry?.[projectId];
  if (!entries || typeof entries !== "object") {
    continue;
  }
  for (const [label, candidateSurface] of Object.entries(entries)) {
    if (normalize(candidateSurface) === surface) {
      process.stdout.write(`${parseRegistryLabel(label)}\n`);
      process.exit(0);
    }
  }
}
NODE
}

format_dispatch_party() {
  local display_label="${1:-}"
  local role="${2:-}"
  local surface="${3:-}"
  local detail="${4:-}"

  local role_label
  role_label="$(dispatch_role_label "$role")"
  display_label="${display_label:-$role_label}"
  local meta=""
  if [ "$display_label" != "$role_label" ]; then
    meta="$role_label"
  fi
  if [ -n "$detail" ]; then
    if [ -n "$meta" ]; then
      meta="${meta}, ${detail}"
    else
      meta="$detail"
    fi
  fi

  if [ -n "$meta" ] && [ -n "$surface" ]; then
    printf '%s (%s, %s)' "$display_label" "$meta" "$surface"
  elif [ -n "$meta" ]; then
    printf '%s (%s)' "$display_label" "$meta"
  elif [ -n "$surface" ]; then
    printf '%s (%s)' "$display_label" "$surface"
  else
    printf '%s' "$display_label"
  fi
}

emit_task_decision_capture() {
  local instruction="${1:-}"
  local task_token="${2:-}"
  local project="${3:-}"
  local task_file="${4:-}"

  [ -n "$instruction" ] || return 0

  KUMA_REPO_ROOT="$KUMA_REPO_ROOT" \
  KUMA_DECISION_RUNTIME_ROOT="${KUMA_DECISION_RUNTIME_ROOT:-$KUMA_REPO_ROOT}" \
  KUMA_VAULT_DIR="$KUMA_VAULT_DIR" \
  node --input-type=module - "$task_token" "$project" "$task_file" "$instruction" <<'NODE' >/dev/null 2>&1 || true
import { join, resolve } from "node:path";
import { pathToFileURL } from "node:url";

const [, , taskTokenRaw, projectRaw, taskFileRaw, instructionRaw] = process.argv;
const taskToken = typeof taskTokenRaw === "string" ? taskTokenRaw.trim() : "";
const project = typeof projectRaw === "string" ? projectRaw.trim() : "";
const taskFile = typeof taskFileRaw === "string" ? taskFileRaw.trim() : "";
const instruction = typeof instructionRaw === "string" ? instructionRaw.trim() : "";
const repoRoot = process.env.KUMA_DECISION_RUNTIME_ROOT
  ? resolve(process.env.KUMA_DECISION_RUNTIME_ROOT)
  : process.env.KUMA_REPO_ROOT
    ? resolve(process.env.KUMA_REPO_ROOT)
    : process.cwd();
const vaultDir = process.env.KUMA_VAULT_DIR;

if (!instruction || !vaultDir) {
  process.exit(0);
}

async function importModule(relativePath) {
  return import(pathToFileURL(join(repoRoot, relativePath)).href);
}

let detectorModule;
let storeModule;
let scopeModule;
try {
  [detectorModule, storeModule, scopeModule] = await Promise.all([
    importModule("packages/server/src/studio/decision-detector.mjs"),
    importModule("packages/server/src/studio/decisions-store.mjs"),
    importModule("packages/server/src/studio/decision-scope.mjs"),
  ]);
} catch {
  process.exit(0);
}

const detectDecision = detectorModule?.detectDecision;
const appendDecision = storeModule?.appendDecision;
const resolveDecisionCaptureScope = scopeModule?.resolveDecisionCaptureScope;
if (
  typeof detectDecision !== "function" ||
  typeof appendDecision !== "function" ||
  typeof resolveDecisionCaptureScope !== "function"
) {
  process.exit(0);
}

const decision = detectDecision({ text: instruction, precedingContext: null });
if (!decision || decision.matched === false || typeof decision.action !== "string" || !decision.action.trim()) {
  process.exit(0);
}

const originalText =
  (typeof decision.original_text === "string" && decision.original_text.trim()) ||
  (typeof decision.originalText === "string" && decision.originalText.trim()) ||
  instruction;
if (!originalText) {
  process.exit(0);
}

await appendDecision({
  vaultDir,
  entry: {
    layer: "inbox",
    action: decision.action.trim(),
    scope: resolveDecisionCaptureScope({
      text: originalText,
      projectName: project,
    }),
    writer: "lifecycle-emitter",
    original_text: originalText,
    context_ref: taskToken ? `task:${taskToken}` : taskFile || "kuma-task",
  },
});
NODE
}

QA_SURFACE=""
QA_LABEL=""
QA_FRONTMATTER=""
QA_MODE="member"
QA_TARGET_QUERY=""
QA_DISPATCH_TARGET=""
if [ "$TRUST_WORKER" = "1" ]; then
  QA_MODE="self"
  QA_LABEL="worker-self-report"
  QA_FRONTMATTER="worker-self-report"
else
  if [ -n "$QA_MEMBER_QUERY" ]; then
    QA_TARGET_QUERY="$QA_MEMBER_QUERY"
  elif [ -n "$MEMBER_DEFAULT_QA" ]; then
    QA_TARGET_QUERY="$MEMBER_DEFAULT_QA"
  elif [ -n "$KUMA_DEFAULT_QA_MEMBER" ]; then
    QA_TARGET_QUERY="$KUMA_DEFAULT_QA_MEMBER"
  else
    QA_TARGET_QUERY="밤토리"
  fi

  case "$QA_TARGET_QUERY" in
    self)
      QA_MODE="self"
      QA_LABEL="worker-self-report"
      QA_FRONTMATTER="worker-self-report"
      QA_DISPATCH_TARGET=""
      ;;
    kuma-direct)
      QA_MODE="kuma-direct"
      QA_LABEL="kuma-direct"
      QA_FRONTMATTER="kuma-direct"
      QA_DISPATCH_TARGET=""
      ;;
    *)
      QA_MEMBER_JSON="$(resolve_member_json "$QA_TARGET_QUERY")" || die "qa member not found: $QA_TARGET_QUERY"
      QA_LABEL="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
      QA_DISPATCH_TARGET="$QA_LABEL"
      QA_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_MEMBER_JSON" 2>/dev/null)" || QA_SURFACE_JSON=""
      QA_MEMBER_ID="$(member_id_from_json "$QA_MEMBER_JSON")"
      QA_STATUS="offline"
      QA_PRIMARY_SUMMARY=""
      QA_FALLBACK_SUMMARY="fallback none"
      QA_NEEDS_FALLBACK=0
      QA_PRIMARY_READY=0

      if [ -n "$QA_SURFACE_JSON" ]; then
        QA_SURFACE="$(surface_id_from_json "$QA_SURFACE_JSON")"
        QA_STATUS_JSON="$(read_project_member_status_json "$TEAM_STATUS_SNAPSHOT_JSON" "$QA_MEMBER_ID")"
        QA_STATUS="$(member_status_field "$QA_STATUS_JSON" state 2>/dev/null || echo "unknown")"
        QA_PRIMARY_SUMMARY="$(format_qa_candidate_summary primary "$QA_LABEL" "$QA_SURFACE" "$QA_STATUS")"
        if [ "$QA_STATUS" = "working" ]; then
          QA_NEEDS_FALLBACK=1
        else
          QA_PRIMARY_READY=1
          QA_FRONTMATTER="$QA_SURFACE"
        fi
      else
        QA_PRIMARY_SUMMARY="$(format_qa_candidate_summary primary "$QA_LABEL" "-" "offline" "unregistered")"
        if QA_SURFACE_JSON="$(spawn_member_surface_json "$PROJECT" "$QA_MEMBER_JSON" "primary QA missing surface")"; then
          QA_SURFACE="$(surface_id_from_json "$QA_SURFACE_JSON")"
          QA_FRONTMATTER="$QA_SURFACE"
          QA_PRIMARY_SUMMARY="$(format_qa_candidate_summary primary "$QA_LABEL" "$QA_SURFACE" "idle" "auto-spawned")"
          QA_PRIMARY_READY=1
        else
          QA_NEEDS_FALLBACK=1
          QA_PRIMARY_SUMMARY="$(format_qa_candidate_summary primary "$QA_LABEL" "-" "offline" "spawn-failed")"
        fi
      fi

      if [ "$QA_NEEDS_FALLBACK" = "1" ]; then
        MEMBER_QA_FALLBACK="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const m=JSON.parse(fs.readFileSync(0,"utf8")); console.log(m.qaFallback || "");' 2>/dev/null || echo "")"
        if [ -n "$MEMBER_QA_FALLBACK" ] && [ "$MEMBER_QA_FALLBACK" != "$QA_TARGET_QUERY" ]; then
          printf 'QA_ROUTE: %s unavailable (state=%s) -> rerouting to alternate reviewer %s\n' "$QA_LABEL" "$QA_STATUS" "$MEMBER_QA_FALLBACK" >&2
          case "$MEMBER_QA_FALLBACK" in
            self)
              QA_FALLBACK_SUMMARY="$(format_qa_candidate_summary fallback worker-self-report "-" "trusted")"
              QA_MODE="self"
              QA_LABEL="worker-self-report"
              QA_FRONTMATTER="worker-self-report"
              QA_SURFACE=""
              QA_DISPATCH_TARGET=""
              ;;
            kuma-direct)
              QA_FALLBACK_SUMMARY="$(format_qa_candidate_summary fallback kuma-direct "-" "direct")"
              QA_MODE="kuma-direct"
              QA_LABEL="kuma-direct"
              QA_FRONTMATTER="kuma-direct"
              QA_SURFACE=""
              QA_DISPATCH_TARGET=""
              ;;
            *)
              QA_FALLBACK_MEMBER_JSON="$(resolve_member_json "$MEMBER_QA_FALLBACK")" || die "qa reroute member not found: $MEMBER_QA_FALLBACK"
              QA_FALLBACK_LABEL="$(printf '%s' "$QA_FALLBACK_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
              QA_FALLBACK_MEMBER_ID="$(member_id_from_json "$QA_FALLBACK_MEMBER_JSON")"
              QA_FALLBACK_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_FALLBACK_MEMBER_JSON" 2>/dev/null)" || QA_FALLBACK_SURFACE_JSON=""
              if [ -n "$QA_FALLBACK_SURFACE_JSON" ]; then
                QA_FALLBACK_SURFACE="$(surface_id_from_json "$QA_FALLBACK_SURFACE_JSON")"
                QA_FALLBACK_STATUS_JSON="$(read_project_member_status_json "$TEAM_STATUS_SNAPSHOT_JSON" "$QA_FALLBACK_MEMBER_ID")"
                QA_FALLBACK_STATUS="$(member_status_field "$QA_FALLBACK_STATUS_JSON" state 2>/dev/null || echo "unknown")"
                QA_FALLBACK_SUMMARY="$(format_qa_candidate_summary fallback "$QA_FALLBACK_LABEL" "$QA_FALLBACK_SURFACE" "$QA_FALLBACK_STATUS")"
                if [ "$QA_FALLBACK_STATUS" = "working" ]; then
                  die "qa route unavailable: ${QA_PRIMARY_SUMMARY}; ${QA_FALLBACK_SUMMARY}"
                fi
              elif QA_FALLBACK_SURFACE_JSON="$(spawn_member_surface_json "$PROJECT" "$QA_FALLBACK_MEMBER_JSON" "fallback QA missing surface")"; then
                QA_FALLBACK_SURFACE="$(surface_id_from_json "$QA_FALLBACK_SURFACE_JSON")"
                QA_FALLBACK_SUMMARY="$(format_qa_candidate_summary fallback "$QA_FALLBACK_LABEL" "$QA_FALLBACK_SURFACE" "idle" "auto-spawned")"
              else
                QA_FALLBACK_SUMMARY="$(format_qa_candidate_summary fallback "$QA_FALLBACK_LABEL" "-" "offline" "spawn-failed")"
                die "qa route unavailable: ${QA_PRIMARY_SUMMARY}; ${QA_FALLBACK_SUMMARY}"
              fi

              QA_MEMBER_JSON="$QA_FALLBACK_MEMBER_JSON"
              QA_DISPATCH_TARGET="$QA_FALLBACK_LABEL"
              QA_LABEL="$QA_FALLBACK_LABEL"
              QA_SURFACE_JSON="$QA_FALLBACK_SURFACE_JSON"
              QA_SURFACE="$QA_FALLBACK_SURFACE"
              QA_FRONTMATTER="$QA_SURFACE"
              ;;
          esac
        elif [ "$QA_PRIMARY_READY" != "1" ]; then
          die "qa route unavailable: ${QA_PRIMARY_SUMMARY}; ${QA_FALLBACK_SUMMARY}"
        fi
      elif [ "$QA_PRIMARY_READY" != "1" ]; then
        die "qa route unavailable: ${QA_PRIMARY_SUMMARY}; ${QA_FALLBACK_SUMMARY}"
      fi

      QA_LABEL="${QA_LABEL:-$QA_TARGET_QUERY}"
      if [ -z "${QA_FRONTMATTER:-}" ]; then
        QA_FRONTMATTER="${QA_SURFACE:-$QA_TARGET_QUERY}"
      fi
      ;;
  esac
fi

TASK_TOKEN="$(default_task_token "$MEMBER_ID")"
TASK_BASENAME="${PROJECT}-${TASK_TOKEN}"
TASK_FILE="$KUMA_TASK_DIR/${TASK_BASENAME}.task.md"
RESULT_FILE="$KUMA_RESULT_DIR/${TASK_BASENAME}.result.md"
SIGNAL="${TASK_BASENAME}-done"
INITIATOR_SURFACE="$(resolve_initiator_surface)"
WORKER_DETAIL="$MEMBER_TYPE"
INITIATOR_NAME="$(resolve_surface_display_name "$INITIATOR_SURFACE" "$PROJECT")"
INITIATOR_LABEL="$(format_dispatch_party "$INITIATOR_NAME" initiator "$INITIATOR_SURFACE")"
WORKER_LABEL="$(format_dispatch_party "$MEMBER_NAME" worker "$WORKER_SURFACE" "$WORKER_DETAIL")"

WORKER_STATUS_JSON="$(read_project_member_status_json "$TEAM_STATUS_SNAPSHOT_JSON" "$MEMBER_ID")"
WORKER_STATUS="$(member_status_field "$WORKER_STATUS_JSON" state 2>/dev/null || echo "unknown")"
WORKER_PREVIEW="$(member_status_field "$WORKER_STATUS_JSON" preview 2>/dev/null || echo "")"
if [ "$WORKER_STATUS" = "working" ]; then
  die "worker surface busy: $WORKER_SURFACE preview=${WORKER_PREVIEW:-working}; requeue or retry later"
fi

cat > "$TASK_FILE" <<EOF
---
id: ${TASK_TOKEN}
project: ${PROJECT}
initiator: ${INITIATOR_SURFACE}
worker: ${WORKER_SURFACE}
qa: ${QA_FRONTMATTER}
signal: ${SIGNAL}
result: ${RESULT_FILE}
---
# ${TASK_BASENAME}

${INSTRUCTION}
EOF

emit_task_decision_capture "$INSTRUCTION" "$TASK_TOKEN" "$PROJECT" "$TASK_FILE"

node "$KUMA_SERVER_CLI" dispatch-register \
  --task-file "$TASK_FILE" \
  --instruction "$INSTRUCTION" \
  --summary "$INSTRUCTION" \
  --initiator-label "$INITIATOR_NAME" \
  --worker-id "$MEMBER_ID" \
  --worker-name "$MEMBER_NAME" \
  --worker-type "$MEMBER_TYPE" \
  --qa-member "$QA_DISPATCH_TARGET" \
  --qa-surface "$QA_SURFACE" \
  --daemon-url "$KUMA_DAEMON_URL" > /dev/null

if [ "$QA_MODE" = "self" ]; then
  PROMPT="$(cat <<EOF
[Kuma Studio Dispatch] ${TASK_TOKEN}
Speaker: ${INITIATOR_LABEL}
Recipient: ${WORKER_LABEL}
Message kind: assigned task
Body source: forwarded/orchestrated summary

${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
Worker trust mode: qa is worker-self-report, so skip Bamdori handoff.
When the work is complete:
- write the result file at ${RESULT_FILE}
- include 'trusted: worker-self-report' in the result file
- report completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
If the task fails or is blocked, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
EOF
)"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  PROMPT="$(cat <<EOF
[Kuma Studio Dispatch] ${TASK_TOKEN}
Speaker: ${INITIATOR_LABEL}
Recipient: ${WORKER_LABEL}
Message kind: assigned task
Body source: forwarded/orchestrated summary

${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
Kuma will review directly, so do not dispatch a separate QA worker.
When the work is complete:
- write the result file at ${RESULT_FILE}
- report completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
If the task fails or is blocked, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
EOF
)"
else
  PROMPT="$(cat <<EOF
[Kuma Studio Dispatch] ${TASK_TOKEN}
Speaker: ${INITIATOR_LABEL}
Recipient: ${WORKER_LABEL}
Message kind: assigned task
Body source: forwarded/orchestrated summary

${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
When implementation is ready:
- write the result file at ${RESULT_FILE}
- report worker completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
- then hand off QA to ${QA_DISPATCH_TARGET} using:
  ~/.kuma/bin/kuma-task "${QA_DISPATCH_TARGET}" "QA this completed task. Read ${TASK_FILE} and ${RESULT_FILE}. Use kuma-picker first. If QA passes, run ~/.kuma/bin/kuma-dispatch qa-pass --task-file ${TASK_FILE}. If QA fails, update ${RESULT_FILE} with the blocker and run ~/.kuma/bin/kuma-dispatch qa-reject --task-file ${TASK_FILE} --blocker \"...\"." --project "${PROJECT}" --trust-worker
If the task fails or is blocked before QA, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
EOF
)"
fi

"$KUMA_CMUX_DIR/kuma-cmux-send.sh" "$WORKER_SURFACE" "$PROMPT"

printf 'TASK_FILE: %s\n' "$TASK_FILE"
printf 'RESULT_FILE: %s\n' "$RESULT_FILE"
printf 'WORKER: %s (%s, %s)\n' "$MEMBER_NAME" "$WORKER_SURFACE" "$MEMBER_TYPE"
if [ "$QA_MODE" = "self" ]; then
  printf 'QA: %s (trusted)\n' "$QA_LABEL"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  printf 'QA: %s (쿠마 직접 리뷰)\n' "$QA_LABEL"
elif [ -n "$QA_SURFACE" ]; then
  printf 'QA: %s (%s)\n' "$QA_LABEL" "$QA_SURFACE"
fi
printf 'SIGNAL: %s\n' "$SIGNAL"
