#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage: kuma-task <멤버이름> "<지시>" [--project <프로젝트>] [--qa <멤버|self|kuma-direct>] [--trust-worker]

Options:
  --qa <멤버>        QA 담당 멤버 override. 우선순위는 --qa > member.defaultQa > KUMA_DEFAULT_QA_MEMBER > 밤토리
  --trust-worker     밤토리 QA를 생략하고 qa: worker-self-report 로 기록
  --no-qa            deprecated alias for --trust-worker
EOF
}

[ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
  usage
  exit 0
}

[ $# -ge 2 ] || {
  usage >&2
  exit 1
}

MEMBER_QUERY="$1"
INSTRUCTION="$2"
shift 2

PROJECT="$KUMA_DEFAULT_PROJECT"
TRUST_WORKER=0
USED_DEPRECATED_NO_QA=0
QA_MEMBER_QUERY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT="${2:?project required}"
      shift 2
      ;;
    --qa)
      QA_MEMBER_QUERY="${2:?qa member required}"
      shift 2
      ;;
    --trust-worker)
      TRUST_WORKER=1
      shift
      ;;
    --no-qa)
      TRUST_WORKER=1
      USED_DEPRECATED_NO_QA=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

if [ "$TRUST_WORKER" = "1" ] && [ -n "$QA_MEMBER_QUERY" ]; then
  die "--qa and --trust-worker cannot be used together"
fi

if [ "$USED_DEPRECATED_NO_QA" = "1" ]; then
  printf '%s\n' "--no-qa is deprecated, use --trust-worker instead. This will still route through vault-auto-ingest." >&2
fi

ensure_runtime_requirements
require_file "$KUMA_CMUX_DIR/kuma-cmux-send.sh"
require_file "$KUMA_CMUX_DIR/kuma-cmux-read.sh"
mkdir -p "$KUMA_TASK_DIR" "$KUMA_RESULT_DIR"

MEMBER_JSON="$(resolve_member_json "$MEMBER_QUERY")" || die "unknown member: $MEMBER_QUERY"
MEMBER_NAME="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
MEMBER_ID="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.id);')"
MEMBER_TYPE="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.type);')"
MEMBER_DEFAULT_QA="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.defaultQa || "");')"

SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$MEMBER_JSON")" || die "surface not found for $MEMBER_NAME in project '$PROJECT'"
WORKER_SURFACE="$(printf '%s' "$SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
TEAM_STATUS_SNAPSHOT_JSON="$(read_team_status_snapshot_json "$PROJECT")"

read_project_member_status_json() {
  local snapshot_json="${1:?snapshot json required}"
  local member_id="${2:?member id required}"

  printf '%s' "$snapshot_json" | node -e '
    const fs = require("node:fs");
    const memberId = process.argv[1];
    const snapshot = JSON.parse(fs.readFileSync(0, "utf8"));
    const projects = Array.isArray(snapshot?.projects) ? snapshot.projects : [];
    for (const project of projects) {
      const members = Array.isArray(project?.members) ? project.members : [];
      const member = members.find((entry) => entry?.id === memberId);
      if (member) {
        process.stdout.write(`${JSON.stringify(member)}\n`);
        process.exit(0);
      }
    }
    process.stdout.write("{}\n");
  ' "$member_id"
}

member_status_field() {
  local member_status_json="${1:?member status json required}"
  local field="${2:?field required}"

  printf '%s' "$member_status_json" | node -e '
    const fs = require("node:fs");
    const data = JSON.parse(fs.readFileSync(0, "utf8"));
    const field = process.argv[1];
    let value = "";
    if (field === "preview") {
      value =
        (typeof data?.task === "string" && data.task.trim()) ||
        (Array.isArray(data?.lastOutputLines) && typeof data.lastOutputLines[0] === "string" ? data.lastOutputLines[0] : "") ||
        "";
    } else if (typeof data?.[field] === "string") {
      value = data[field];
    }
    process.stdout.write(`${value}\n`);
  ' "$field"
}

QA_SURFACE=""
QA_LABEL=""
QA_FRONTMATTER=""
QA_MODE="member"
QA_TARGET_QUERY=""
QA_DISPATCH_TARGET=""
if [ "$TRUST_WORKER" = "1" ]; then
  QA_MODE="self"
  QA_LABEL="worker-self-report"
  QA_FRONTMATTER="worker-self-report"
else
  if [ -n "$QA_MEMBER_QUERY" ]; then
    QA_TARGET_QUERY="$QA_MEMBER_QUERY"
  elif [ -n "$MEMBER_DEFAULT_QA" ]; then
    QA_TARGET_QUERY="$MEMBER_DEFAULT_QA"
  elif [ -n "$KUMA_DEFAULT_QA_MEMBER" ]; then
    QA_TARGET_QUERY="$KUMA_DEFAULT_QA_MEMBER"
  else
    QA_TARGET_QUERY="밤토리"
  fi

  case "$QA_TARGET_QUERY" in
    self)
      QA_MODE="self"
      QA_LABEL="worker-self-report"
      QA_FRONTMATTER="worker-self-report"
      QA_DISPATCH_TARGET=""
      ;;
    kuma-direct)
      QA_MODE="kuma-direct"
      QA_LABEL="kuma-direct"
      QA_FRONTMATTER="kuma-direct"
      QA_DISPATCH_TARGET=""
      ;;
    *)
      QA_MEMBER_JSON="$(resolve_member_json "$QA_TARGET_QUERY")" || die "qa member not found: $QA_TARGET_QUERY"
      QA_LABEL="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
      QA_DISPATCH_TARGET="$QA_LABEL"
      QA_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_MEMBER_JSON" 2>/dev/null)" || QA_SURFACE_JSON=""

      # QA fallback: surface 없거나 busy면 fallback 멤버로 전환
      QA_BUSY=0
      if [ -z "$QA_SURFACE_JSON" ]; then
        QA_BUSY=1
      else
        QA_SURFACE="$(printf '%s' "$QA_SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
        QA_MEMBER_ID="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.id);')"
        QA_STATUS_JSON="$(read_project_member_status_json "$TEAM_STATUS_SNAPSHOT_JSON" "$QA_MEMBER_ID")"
        QA_STATUS="$(member_status_field "$QA_STATUS_JSON" state 2>/dev/null || echo "unknown")"
        if [ "$QA_STATUS" = "working" ]; then
          QA_BUSY=1
        fi
      fi

      if [ "$QA_BUSY" = "1" ]; then
        # fallback 멤버 조회 (worker의 qaFallback 필드)
        MEMBER_QA_FALLBACK="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const m=JSON.parse(fs.readFileSync(0,"utf8")); console.log(m.qaFallback || "");' 2>/dev/null || echo "")"
        if [ -n "$MEMBER_QA_FALLBACK" ] && [ "$MEMBER_QA_FALLBACK" != "$QA_TARGET_QUERY" ]; then
          printf 'QA_FALLBACK: %s busy → trying %s\n' "$QA_TARGET_QUERY" "$MEMBER_QA_FALLBACK" >&2
          case "$MEMBER_QA_FALLBACK" in
            self)
              QA_MODE="self"
              QA_LABEL="worker-self-report (fallback)"
              QA_FRONTMATTER="worker-self-report"
              QA_SURFACE=""
              QA_DISPATCH_TARGET=""
              ;;
            kuma-direct)
              QA_MODE="kuma-direct"
              QA_LABEL="kuma-direct (fallback)"
              QA_FRONTMATTER="kuma-direct"
              QA_SURFACE=""
              QA_DISPATCH_TARGET=""
              ;;
            *)
              QA_MEMBER_JSON="$(resolve_member_json "$MEMBER_QA_FALLBACK")" || die "qa fallback member not found: $MEMBER_QA_FALLBACK"
              QA_DISPATCH_TARGET="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
              QA_LABEL="${QA_DISPATCH_TARGET} (fallback)"
              QA_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_MEMBER_JSON" 2>/dev/null)" || die "qa fallback surface not found for $MEMBER_QA_FALLBACK"
              QA_SURFACE="$(printf '%s' "$QA_SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
              QA_FRONTMATTER="$QA_SURFACE"
              ;;
          esac
        fi
      fi

      QA_LABEL="${QA_LABEL:-$QA_TARGET_QUERY}"
      if [ -z "${QA_FRONTMATTER:-}" ]; then
        QA_FRONTMATTER="${QA_SURFACE:-$QA_TARGET_QUERY}"
      fi
      ;;
  esac
fi

TASK_TOKEN="$(default_task_token "$MEMBER_ID")"
TASK_BASENAME="${PROJECT}-${TASK_TOKEN}"
TASK_FILE="$KUMA_TASK_DIR/${TASK_BASENAME}.task.md"
RESULT_FILE="$KUMA_RESULT_DIR/${TASK_BASENAME}.result.md"
SIGNAL="${TASK_BASENAME}-done"
INITIATOR_SURFACE="$(resolve_initiator_surface)"

WORKER_STATUS_JSON="$(read_project_member_status_json "$TEAM_STATUS_SNAPSHOT_JSON" "$MEMBER_ID")"
WORKER_STATUS="$(member_status_field "$WORKER_STATUS_JSON" state 2>/dev/null || echo "unknown")"
WORKER_PREVIEW="$(member_status_field "$WORKER_STATUS_JSON" preview 2>/dev/null || echo "")"
if [ "$WORKER_STATUS" = "working" ]; then
  die "worker surface busy: $WORKER_SURFACE preview=${WORKER_PREVIEW:-working}; requeue or retry later"
fi

cat > "$TASK_FILE" <<EOF
---
id: ${TASK_TOKEN}
project: ${PROJECT}
initiator: ${INITIATOR_SURFACE}
worker: ${WORKER_SURFACE}
qa: ${QA_FRONTMATTER}
signal: ${SIGNAL}
result: ${RESULT_FILE}
---
# ${TASK_BASENAME}

${INSTRUCTION}
EOF

node "$KUMA_SERVER_CLI" dispatch-register \
  --task-file "$TASK_FILE" \
  --instruction "$INSTRUCTION" \
  --summary "$INSTRUCTION" \
  --worker-id "$MEMBER_ID" \
  --worker-name "$MEMBER_NAME" \
  --worker-type "$MEMBER_TYPE" \
  --qa-member "$QA_DISPATCH_TARGET" \
  --qa-surface "$QA_SURFACE" \
  --daemon-url "$KUMA_DAEMON_URL" > /dev/null

# 오케스트레이터(team nodeType) 멤버에게는 분배 규칙 강제 삽입
MEMBER_NODE_TYPE="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const m=JSON.parse(fs.readFileSync(0,"utf8")); console.log(m.nodeType || "worker");')"
ORCHESTRATOR_FOOTER=""
if [ "$MEMBER_NODE_TYPE" = "team" ]; then
  ORCHESTRATOR_FOOTER="

[오케스트레이터 규칙]
- 직접 구현 금지. 1줄 이하 trivial fix만 예외.
- 워커에게 kuma-task로 분배 필수.
- 워커 태스크는 QA(밤토리)를 거치게 할 것. --trust-worker 사용 금지.
- 순서: 플랜 작성 → 워커 분배 → 워커 QA 통과 → 결과 수합 → 시그널 발신."
fi

if [ "$QA_MODE" = "self" ]; then
  PROMPT="$(cat <<EOF
${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
Worker trust mode: qa is worker-self-report, so skip Bamdori handoff.
When the work is complete:
- write the result file at ${RESULT_FILE}
- include 'trusted: worker-self-report' in the result file
- report completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
If the task fails or is blocked, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
${ORCHESTRATOR_FOOTER}
EOF
)"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  PROMPT="$(cat <<EOF
${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
Kuma will review directly, so do not dispatch a separate QA worker.
When the work is complete:
- write the result file at ${RESULT_FILE}
- report completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
If the task fails or is blocked, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
${ORCHESTRATOR_FOOTER}
EOF
)"
else
  PROMPT="$(cat <<EOF
${INSTRUCTION}

Tracked task file: ${TASK_FILE}
If you need clarification or want to send progress before completion:
- ask in-thread with ~/.kuma/bin/kuma-dispatch ask --task-file ${TASK_FILE} --message "..."
- reply in-thread with ~/.kuma/bin/kuma-dispatch reply --task-file ${TASK_FILE} --message "..."
When implementation is ready:
- write the result file at ${RESULT_FILE}
- report worker completion with ~/.kuma/bin/kuma-dispatch complete --task-file ${TASK_FILE}
- then hand off QA to ${QA_DISPATCH_TARGET} using:
  ~/.kuma/bin/kuma-task "${QA_DISPATCH_TARGET}" "QA this completed task. Read ${TASK_FILE} and ${RESULT_FILE}. Use kuma-picker first. If QA passes, run ~/.kuma/bin/kuma-dispatch qa-pass --task-file ${TASK_FILE}. If QA fails, update ${RESULT_FILE} with the blocker and run ~/.kuma/bin/kuma-dispatch qa-reject --task-file ${TASK_FILE} --blocker \"...\"." --project "${PROJECT}" --trust-worker
If the task fails or is blocked before QA, write the result file and report ~/.kuma/bin/kuma-dispatch fail --task-file ${TASK_FILE} --blocker "..."
${ORCHESTRATOR_FOOTER}
EOF
)"
fi

"$KUMA_CMUX_DIR/kuma-cmux-send.sh" "$WORKER_SURFACE" "$PROMPT"

printf 'TASK_FILE: %s\n' "$TASK_FILE"
printf 'RESULT_FILE: %s\n' "$RESULT_FILE"
printf 'WORKER: %s (%s, %s)\n' "$MEMBER_NAME" "$WORKER_SURFACE" "$MEMBER_TYPE"
if [ "$QA_MODE" = "self" ]; then
  printf 'QA: %s (trusted)\n' "$QA_LABEL"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  printf 'QA: %s (쿠마 직접 리뷰)\n' "$QA_LABEL"
elif [ -n "$QA_SURFACE" ]; then
  printf 'QA: %s (%s)\n' "$QA_LABEL" "$QA_SURFACE"
fi
printf 'SIGNAL: %s\n' "$SIGNAL"
