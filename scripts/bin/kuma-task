#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage: kuma-task <멤버이름> "<지시>" [--project <프로젝트>] [--qa <멤버|self|kuma-direct>] [--trust-worker] [--wait] [--wait-timeout <sec>] [--timeout <sec>] [--poll]

Options:
  --qa <멤버>        QA 담당 멤버 override. 우선순위는 --qa > member.defaultQa > KUMA_DEFAULT_QA_MEMBER > 밤토리
  --trust-worker     밤토리 QA를 생략하고 qa: worker-self-report 로 기록
  --wait             디스패치 후 exact signal file 을 감시하고 result 내용을 출력
  --wait-timeout <sec>  최대 대기 시간. 기본 600초
  --timeout <sec>    --wait-timeout 과 동일한 호환 alias
  --poll             signal 대신 result file 존재를 폴링하며 대기
  --no-qa            deprecated alias for --trust-worker
EOF
}

resolve_vault_prompt_prefix() {
  local instruction="${1:-}"
  local member_json="${2-}"
  local vault_dir="$KUMA_HOME_DIR/vault"

  if [ -z "$member_json" ]; then
    member_json='{}'
  fi

  KUMA_VAULT_MEMBER_JSON="$member_json" node --input-type=module - "$vault_dir" "$instruction" <<'NODE'
import { existsSync, readFileSync } from "node:fs";
import { basename, join } from "node:path";

const [, , vaultDir, instructionRaw = ""] = process.argv;
const domainsDir = join(vaultDir, "domains");
const indexPath = join(vaultDir, "index.md");
const instruction = String(instructionRaw || "").toLowerCase();

let member = {};
try {
  const memberJsonRaw = process.env.KUMA_VAULT_MEMBER_JSON || "{}";
  member = JSON.parse(memberJsonRaw || "{}");
} catch {
  member = {};
}

const manualKeywordMap = {
  analytics: ["analytics", "분석", "usage", "insight", "통계", "리포트", "report"],
  careers: ["career", "careers", "resume", "cv", "이력서", "경력", "포트폴리오"],
  "content-pipeline": ["콘텐츠", "content", "카드뉴스", "video", "영상", "tts", "remotion"],
  "image-generation": ["이미지", "image", "캐릭터", "design", "디자인", "branding", "브랜딩", "illustration", "일러스트", "mascot", "마스코트"],
  "kuma-picker": ["picker", "selection", "브라우저 선택", "선택 요소", "dom"],
  "kuma-vault": ["vault", "지식", "memory", "wiki"],
  security: ["보안", "security", "kisa", "owasp", "asvs", "ssdf", "threat", "intel", "credential", "infostealer"],
  "team-system": ["team.json", "team json", "팀 시스템", "worker", "워커", "surface", "qa", "normalizer", "classifier", "bootstrap"],
};

function normalize(value) {
  return String(value || "").toLowerCase();
}

function tokenize(value) {
  return Array.from(new Set(
    normalize(value)
      .split(/[^a-z0-9가-힣]+/u)
      .map((token) => token.trim())
      .filter((token) => token.length >= 2),
  ));
}

function parseDomainIndex(path) {
  if (!existsSync(path)) {
    return [];
  }

  const lines = readFileSync(path, "utf8").split(/\r?\n/u);
  const domains = [];
  let inDomains = false;

  for (const line of lines) {
    if (/^##\s+Domains\b/u.test(line)) {
      inDomains = true;
      continue;
    }
    if (inDomains && /^##\s+/u.test(line)) {
      break;
    }
    if (!inDomains) {
      continue;
    }

    const match = line.match(/^- \[([^\]]+)\]\(([^)]+)\)\s*(?:—|-)\s*(.*)$/u);
    if (!match) {
      continue;
    }

    const [, title, relativePath, description] = match;
    domains.push({
      slug: basename(relativePath, ".md"),
      title,
      description,
      paths: [relativePath],
    });
  }

  return domains;
}

function getExplicitVaultDomains(rawMember) {
  if (!Array.isArray(rawMember?.vaultDomains)) {
    return [];
  }
  return rawMember.vaultDomains
    .filter((value) => typeof value === "string")
    .map((value) => value.trim())
    .filter(Boolean);
}

const parsedDomains = parseDomainIndex(indexPath);
const explicitDomains = getExplicitVaultDomains(member);

const rankedDomains = parsedDomains
  .map((domain, index) => {
    let score = 0;
    const keywords = new Set([
      ...tokenize(domain.slug),
      ...tokenize(domain.title),
      ...(manualKeywordMap[domain.slug] || []).map((value) => normalize(value)),
    ]);

    for (const keyword of keywords) {
      if (!keyword || !instruction.includes(keyword)) {
        continue;
      }
      score += keyword.length >= 5 ? 3 : 2;
    }

    return {
      ...domain,
      index,
      score,
    };
  })
  .filter((domain) => domain.score > 0)
  .sort((left, right) => right.score - left.score || left.index - right.index || left.slug.localeCompare(right.slug));

const selected = [];
const seen = new Set();

function tryAdd(slug) {
  if (!slug || seen.has(slug) || selected.length >= 3) {
    return;
  }
  if (!existsSync(join(domainsDir, `${slug}.md`))) {
    return;
  }
  seen.add(slug);
  selected.push(slug);
}

for (const slug of explicitDomains) {
  tryAdd(slug);
}

for (const domain of rankedDomains) {
  tryAdd(domain.slug);
}

if (selected.length > 0) {
  process.stdout.write(
    `${selected.map((slug) => `Read ~/.kuma/vault/domains/${slug}.md 를 먼저 읽고 참고한 뒤 작업을 시작할 것.`).join("\n")}\n`,
  );
}
NODE
}

[ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
  usage
  exit 0
}

[ $# -ge 2 ] || {
  usage >&2
  exit 1
}

MEMBER_QUERY="$1"
INSTRUCTION="$2"
shift 2

PROJECT="$KUMA_DEFAULT_PROJECT"
WAIT_FOR_SIGNAL=0
WAIT_TIMEOUT=600
WAIT_MODE="signal"
TRUST_WORKER=0
USED_DEPRECATED_NO_QA=0
QA_MEMBER_QUERY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT="${2:?project required}"
      shift 2
      ;;
    --qa)
      QA_MEMBER_QUERY="${2:?qa member required}"
      shift 2
      ;;
    --trust-worker)
      TRUST_WORKER=1
      shift
      ;;
    --wait)
      WAIT_FOR_SIGNAL=1
      shift
      ;;
    --wait-timeout)
      WAIT_TIMEOUT="${2:?timeout seconds required}"
      WAIT_FOR_SIGNAL=1
      shift 2
      ;;
    --timeout)
      WAIT_TIMEOUT="${2:?timeout seconds required}"
      WAIT_FOR_SIGNAL=1
      shift 2
      ;;
    --poll)
      WAIT_FOR_SIGNAL=1
      WAIT_MODE="poll"
      shift
      ;;
    --no-qa)
      TRUST_WORKER=1
      USED_DEPRECATED_NO_QA=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

if [ "$TRUST_WORKER" = "1" ] && [ -n "$QA_MEMBER_QUERY" ]; then
  die "--qa and --trust-worker cannot be used together"
fi

if [ "$USED_DEPRECATED_NO_QA" = "1" ]; then
  printf '%s\n' "--no-qa is deprecated, use --trust-worker instead. This will still route through vault-auto-ingest." >&2
fi

ensure_runtime_requirements
require_file "$KUMA_CMUX_DIR/kuma-cmux-send.sh"
mkdir -p "$KUMA_TASK_DIR" "$KUMA_RESULT_DIR"

MEMBER_JSON="$(resolve_member_json "$MEMBER_QUERY")" || die "unknown member: $MEMBER_QUERY"
MEMBER_NAME="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
MEMBER_ID="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.id);')"
MEMBER_TYPE="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.type);')"
MEMBER_DEFAULT_QA="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.defaultQa || "");')"

SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$MEMBER_JSON")" || die "surface not found for $MEMBER_NAME in project '$PROJECT'"
WORKER_SURFACE="$(printf '%s' "$SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"

QA_SURFACE=""
QA_LABEL=""
QA_FRONTMATTER=""
QA_MODE="member"
QA_TARGET_QUERY=""
if [ "$TRUST_WORKER" = "1" ]; then
  QA_MODE="self"
  QA_LABEL="worker-self-report"
  QA_FRONTMATTER="worker-self-report"
else
  if [ -n "$QA_MEMBER_QUERY" ]; then
    QA_TARGET_QUERY="$QA_MEMBER_QUERY"
  elif [ -n "$MEMBER_DEFAULT_QA" ]; then
    QA_TARGET_QUERY="$MEMBER_DEFAULT_QA"
  elif [ -n "$KUMA_DEFAULT_QA_MEMBER" ]; then
    QA_TARGET_QUERY="$KUMA_DEFAULT_QA_MEMBER"
  else
    QA_TARGET_QUERY="밤토리"
  fi

  case "$QA_TARGET_QUERY" in
    self)
      QA_MODE="self"
      QA_LABEL="worker-self-report"
      QA_FRONTMATTER="worker-self-report"
      ;;
    kuma-direct)
      QA_MODE="kuma-direct"
      QA_LABEL="kuma-direct"
      QA_FRONTMATTER="kuma-direct"
      ;;
    *)
      QA_MEMBER_JSON="$(resolve_member_json "$QA_TARGET_QUERY")" || die "qa member not found: $QA_TARGET_QUERY"
      QA_LABEL="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);')"
      QA_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_MEMBER_JSON" 2>/dev/null)" || QA_SURFACE_JSON=""

      # QA fallback: surface 없거나 busy면 fallback 멤버로 전환
      QA_BUSY=0
      if [ -z "$QA_SURFACE_JSON" ]; then
        QA_BUSY=1
      else
        QA_SURFACE="$(printf '%s' "$QA_SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
        # surface status 체크
        QA_STATUS="$(("$KUMA_CMUX_DIR/kuma-cmux-read.sh" "$QA_SURFACE" 2>/dev/null || echo "") | classify_surface_output_json | node -e 'const fs=require("node:fs"); const d=JSON.parse(fs.readFileSync(0,"utf8")); console.log(d.status);' 2>/dev/null || echo "unknown")"
        if [ "$QA_STATUS" = "working" ]; then
          QA_BUSY=1
        fi
      fi

      if [ "$QA_BUSY" = "1" ]; then
        # fallback 멤버 조회 (worker의 qaFallback 필드)
        MEMBER_QA_FALLBACK="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const m=JSON.parse(fs.readFileSync(0,"utf8")); console.log(m.qaFallback || "");' 2>/dev/null || echo "")"
        if [ -n "$MEMBER_QA_FALLBACK" ] && [ "$MEMBER_QA_FALLBACK" != "$QA_TARGET_QUERY" ]; then
          printf 'QA_FALLBACK: %s busy → trying %s\n' "$QA_TARGET_QUERY" "$MEMBER_QA_FALLBACK" >&2
          case "$MEMBER_QA_FALLBACK" in
            self)
              QA_MODE="self"
              QA_LABEL="worker-self-report (fallback)"
              QA_FRONTMATTER="worker-self-report"
              QA_SURFACE=""
              ;;
            kuma-direct)
              QA_MODE="kuma-direct"
              QA_LABEL="kuma-direct (fallback)"
              QA_FRONTMATTER="kuma-direct"
              QA_SURFACE=""
              ;;
            *)
              QA_MEMBER_JSON="$(resolve_member_json "$MEMBER_QA_FALLBACK")" || die "qa fallback member not found: $MEMBER_QA_FALLBACK"
              QA_LABEL="$(printf '%s' "$QA_MEMBER_JSON" | node -e 'const fs=require("node:fs"); const member=JSON.parse(fs.readFileSync(0,"utf8")); console.log(member.displayName);') (fallback)"
              QA_SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$QA_MEMBER_JSON" 2>/dev/null)" || die "qa fallback surface not found for $MEMBER_QA_FALLBACK"
              QA_SURFACE="$(printf '%s' "$QA_SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
              QA_FRONTMATTER="$QA_SURFACE"
              ;;
          esac
        fi
      fi

      QA_LABEL="${QA_LABEL:-$QA_TARGET_QUERY}"
      if [ -z "${QA_FRONTMATTER:-}" ]; then
        QA_FRONTMATTER="${QA_SURFACE:-$QA_TARGET_QUERY}"
      fi
      ;;
  esac
fi

TASK_TOKEN="$(default_task_token "$MEMBER_ID")"
TASK_BASENAME="${PROJECT}-${TASK_TOKEN}"
TASK_FILE="$KUMA_TASK_DIR/${TASK_BASENAME}.task.md"
RESULT_FILE="$KUMA_RESULT_DIR/${TASK_BASENAME}.result.md"
SIGNAL="${TASK_BASENAME}-done"
INITIATOR_SURFACE="$(resolve_initiator_surface)"

cat > "$TASK_FILE" <<EOF
---
id: ${TASK_TOKEN}
project: ${PROJECT}
initiator: ${INITIATOR_SURFACE}
worker: ${WORKER_SURFACE}
qa: ${QA_FRONTMATTER}
signal: ${SIGNAL}
result: ${RESULT_FILE}
---
# ${TASK_BASENAME}

${INSTRUCTION}
EOF

# 오케스트레이터(team nodeType) 멤버에게는 분배 규칙 강제 삽입
MEMBER_NODE_TYPE="$(printf '%s' "$MEMBER_JSON" | node -e 'const fs=require("node:fs"); const m=JSON.parse(fs.readFileSync(0,"utf8")); console.log(m.nodeType || "worker");')"
ORCHESTRATOR_FOOTER=""
if [ "$MEMBER_NODE_TYPE" = "team" ]; then
  ORCHESTRATOR_FOOTER="

[오케스트레이터 규칙]
- 직접 구현 금지. 1줄 이하 trivial fix만 예외.
- 워커에게 kuma-task로 분배 필수.
- 워커 태스크는 QA(밤토리)를 거치게 할 것. --trust-worker 사용 금지.
- 순서: 플랜 작성 → 워커 분배 → 워커 QA 통과 → 결과 수합 → 시그널 발신."
fi

VAULT_PROMPT_PREFIX="$(resolve_vault_prompt_prefix "$INSTRUCTION" "$MEMBER_JSON")"

if [ "$QA_MODE" = "self" ]; then
  PROMPT="Read ${TASK_FILE} and execute. Worker trust mode: qa is worker-self-report, so skip Bamdori handoff. 완료 후 result 파일에 'trusted: worker-self-report' 표시를 남기고 mkdir -p /tmp/kuma-signals && touch /tmp/kuma-signals/${SIGNAL} 로 완료 신호 보낼 것.${ORCHESTRATOR_FOOTER}"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  PROMPT="Read ${TASK_FILE} and execute. 완료 후 result 파일 작성 후 mkdir -p /tmp/kuma-signals && touch /tmp/kuma-signals/${SIGNAL} 로 완료 신호 보낼 것. 쿠마가 직접 리뷰함.${ORCHESTRATOR_FOOTER}"
else
  PROMPT="Read ${TASK_FILE} and execute. 완료 후 QA 라우팅 프로토콜 따를 것.${ORCHESTRATOR_FOOTER}"
fi

if [ -n "$VAULT_PROMPT_PREFIX" ]; then
  PROMPT="${VAULT_PROMPT_PREFIX}
${PROMPT}"
fi

"$KUMA_CMUX_DIR/kuma-cmux-send.sh" "$WORKER_SURFACE" "$PROMPT"

printf 'TASK_FILE: %s\n' "$TASK_FILE"
printf 'RESULT_FILE: %s\n' "$RESULT_FILE"
printf 'WORKER: %s (%s, %s)\n' "$MEMBER_NAME" "$WORKER_SURFACE" "$MEMBER_TYPE"
if [ "$QA_MODE" = "self" ]; then
  printf 'QA: %s (trusted)\n' "$QA_LABEL"
elif [ "$QA_MODE" = "kuma-direct" ]; then
  printf 'QA: %s (쿠마 직접 리뷰)\n' "$QA_LABEL"
elif [ -n "$QA_SURFACE" ]; then
  printf 'QA: %s (%s)\n' "$QA_LABEL" "$QA_SURFACE"
fi
printf 'SIGNAL: %s\n' "$SIGNAL"

if [ "$WAIT_FOR_SIGNAL" = "1" ]; then
  if [ "$WAIT_MODE" = "poll" ]; then
    poll_result_file_with_diagnostics "$RESULT_FILE" "$WORKER_SURFACE" "$WAIT_TIMEOUT"
  else
    wait_for_signal_with_diagnostics "$SIGNAL" "$RESULT_FILE" "$WORKER_SURFACE" "$WAIT_TIMEOUT"
  fi
  ingest_result_file_to_vault "$RESULT_FILE"
fi
