#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage: kuma-kill <멤버이름> [--project <프로젝트>]
       kuma-kill --surface <surface-id>
EOF
}

[ $# -ge 1 ] || {
  usage >&2
  exit 1
}

MEMBER_QUERY=""
PROJECT=""
SURFACE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT="${2:?project required}"
      shift 2
      ;;
    --surface)
      SURFACE="${2:?surface required}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -n "$MEMBER_QUERY" ]; then
        die "member already specified: $MEMBER_QUERY"
      fi
      MEMBER_QUERY="$1"
      shift
      ;;
  esac
done

ensure_runtime_requirements
ensure_surface_registry

if [ -z "$SURFACE" ]; then
  [ -n "$MEMBER_QUERY" ] || die "member name or --surface is required"
  MEMBER_JSON="$(resolve_member_json "$MEMBER_QUERY")" || die "unknown member: $MEMBER_QUERY"

  if [ -z "$PROJECT" ]; then
    PROJECT="$(resolve_project_from_dir "$(pwd)" || true)"
  fi

  SURFACE_JSON="$(resolve_surface_json "$PROJECT" "$MEMBER_JSON")" || die "surface not found for $MEMBER_QUERY"
  SURFACE="$(printf '%s' "$SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.surface);')"
  if [ -z "$PROJECT" ]; then
    PROJECT="$(printf '%s' "$SURFACE_JSON" | node -e 'const fs=require("node:fs"); const surface=JSON.parse(fs.readFileSync(0,"utf8")); console.log(surface.project || "");')"
  fi
fi

"$KUMA_CMUX_DIR/kuma-cmux-kill.sh" "$SURFACE"
remove_surface_from_registry "$SURFACE" "$PROJECT"

printf 'SURFACE: %s\n' "$SURFACE"
if [ -n "$PROJECT" ]; then
  printf 'PROJECT: %s\n' "$PROJECT"
fi
