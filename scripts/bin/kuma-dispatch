#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage:
  kuma-dispatch assign <멤버이름> "<지시>" [--project <프로젝트>] [--attach <path>] [--qa <멤버|self|none>] [--require-result]
  kuma-dispatch send <멤버이름> "<지시>" [assign options...]
  kuma-dispatch ask --task-file <path> --message <text> [--to initiator|worker|qa|surface:7]
  kuma-dispatch reply --task-file <path> --message <text> [--to initiator|worker|qa|surface:7]
  kuma-dispatch message --task-file <path> --kind <question|answer|status|note|blocker> --message <text> [--to initiator|worker|qa|surface:7]
  kuma-dispatch done --task-file <path> [--summary <text>] [--note <text>] [--result-file <path>]
  kuma-dispatch complete --task-file <path> [--summary <text>] [--note <text>] [--result-file <path>]
  kuma-dispatch fail --task-file <path> --blocker <text> [--summary <text>] [--note <text>] [--result-file <path>]
  kuma-dispatch qa-pass --task-file <path> [--note <text>] [--result-file <path>]
  kuma-dispatch qa-reject --task-file <path> --blocker <text> [--note <text>] [--result-file <path>]
  kuma-dispatch status --task-file <path>
EOF
}

[ $# -ge 1 ] || {
  usage >&2
  exit 1
}

COMMAND="$1"
shift

require_cmd node

KUMA_LIFECYCLE_TRACE_LOG="${KUMA_LIFECYCLE_TRACE_LOG:-$HOME/.kuma/runtime/lifecycle-trace.log}"

json_field() {
  local field="${1:?field required}"
  node -e '
    const fs = require("node:fs");
    const field = process.argv[1];
    const data = JSON.parse(fs.readFileSync(0, "utf8"));
    const segments = field.split(".").filter(Boolean);
    let value = data;
    for (const segment of segments) {
      if (value == null || typeof value !== "object" || !(segment in value)) {
        value = "";
        break;
      }
      value = value[segment];
    }
    if (typeof value === "string") {
      process.stdout.write(`${value}\n`);
    }
  ' "$field"
}

member_status_from_snapshot() {
  local snapshot_json="${1:?snapshot json required}"
  local member_id="${2:?member id required}"

  printf '%s' "$snapshot_json" | node -e '
    const fs = require("node:fs");
    const memberId = process.argv[1];
    const snapshot = JSON.parse(fs.readFileSync(0, "utf8"));
    const projects = Array.isArray(snapshot?.projects) ? snapshot.projects : [];
    for (const project of projects) {
      const members = Array.isArray(project?.members) ? project.members : [];
      const member = members.find((entry) => entry?.id === memberId);
      if (member) {
        process.stdout.write(`${JSON.stringify(member)}\n`);
        process.exit(0);
      }
    }
    process.stdout.write("{}\n");
  ' "$member_id"
}

member_status_field() {
  local member_status_json="${1:?member status json required}"
  local field="${2:?field required}"

  printf '%s' "$member_status_json" | node -e '
    const fs = require("node:fs");
    const data = JSON.parse(fs.readFileSync(0, "utf8"));
    const field = process.argv[1];
    let value = "";
    if (field === "preview") {
      value =
        (typeof data?.task === "string" && data.task.trim()) ||
        (Array.isArray(data?.lastOutputLines) && typeof data.lastOutputLines[0] === "string" ? data.lastOutputLines[0] : "") ||
        "";
    } else if (typeof data?.[field] === "string") {
      value = data[field];
    }
    process.stdout.write(`${value}\n`);
  ' "$field"
}

run_assign() {
  [ $# -ge 2 ] || {
    usage >&2
    exit 1
  }

  local member_query="$1"
  local instruction="$2"
  shift 2

  local project=""
  local qa_query="none"
  local require_result=0
  local -a attachments=()

  project="$(resolve_default_project || true)"

  while [ $# -gt 0 ]; do
    case "$1" in
      --project)
        project="${2:?project required}"
        shift 2
        ;;
      --attach)
        attachments+=("${2:?attachment path required}")
        shift 2
        ;;
      --qa)
        qa_query="${2:?qa target required}"
        shift 2
        ;;
      --require-result)
        require_result=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown assign argument: $1"
        ;;
    esac
  done

  [ -n "$project" ] || die "project could not be resolved; pass --project"
  ensure_runtime_requirements
  require_file "$KUMA_CMUX_DIR/kuma-cmux-send.sh"
  mkdir -p "$KUMA_TASK_DIR" "$KUMA_RESULT_DIR"

  local member_json=""
  local member_name=""
  local member_id=""
  local member_type=""
  local surface_json=""
  local worker_surface=""
  local team_status_json=""
  local worker_status_json=""
  local worker_state=""
  local worker_preview=""
  local qa_frontmatter=""
  local qa_member=""
  local qa_surface=""
  local task_token=""
  local task_basename=""
  local task_file=""
  local result_file=""
  local signal=""
  local initiator_surface=""
  local initiator_name=""
  local attachment_lines=""
  local prompt_attachments=""
  local prompt_result=""
  local prompt_footer=""

  member_json="$(resolve_member_json "$member_query")" || die "unknown member: $member_query"
  member_name="$(printf '%s' "$member_json" | json_field displayName)"
  member_id="$(printf '%s' "$member_json" | json_field id)"
  member_type="$(printf '%s' "$member_json" | json_field type)"
  surface_json="$(resolve_surface_json "$project" "$member_json")" || die "surface not found for $member_name in project '$project'"
  worker_surface="$(printf '%s' "$surface_json" | json_field surface)"

  team_status_json="$(read_team_status_snapshot_json "$project" 2>/dev/null || printf '{}')"
  worker_status_json="$(member_status_from_snapshot "$team_status_json" "$member_id")"
  worker_state="$(member_status_field "$worker_status_json" state 2>/dev/null || echo "")"
  worker_preview="$(member_status_field "$worker_status_json" preview 2>/dev/null || echo "")"
  if [ "$worker_state" = "working" ]; then
    die "worker surface busy: $worker_surface preview=${worker_preview:-working}; retry later"
  fi

  case "$qa_query" in
    ""|none)
      qa_frontmatter=""
      ;;
    self)
      qa_frontmatter="worker-self-report"
      ;;
    *)
      local qa_json=""
      qa_json="$(resolve_member_json "$qa_query")" || die "qa member not found: $qa_query"
      qa_member="$(printf '%s' "$qa_json" | json_field displayName)"
      qa_surface="$(resolve_surface_json "$project" "$qa_json" 2>/dev/null | node -e 'const fs=require("node:fs"); const raw=fs.readFileSync(0,"utf8").trim(); if (raw) process.stdout.write(JSON.parse(raw).surface || "");' || true)"
      qa_frontmatter="${qa_surface:-$qa_member}"
      ;;
  esac

  task_token="$(default_task_token "$member_id")"
  task_basename="${project}-${task_token}"
  task_file="$KUMA_TASK_DIR/${task_basename}.task.md"
  signal="${task_basename}-done"
  if [ "$require_result" = "1" ]; then
    result_file="$KUMA_RESULT_DIR/${task_basename}.result.md"
    prompt_result="Result: ${result_file}"
  fi
  initiator_surface="$(resolve_initiator_surface)"
  initiator_name="$(resolve_dispatch_party_display_name initiator "$initiator_surface" "$project")"

  if [ "${#attachments[@]}" -gt 0 ]; then
    attachment_lines="## Attachments"$'\n'
    prompt_attachments="Attachments:"$'\n'
    for attachment in "${attachments[@]}"; do
      attachment_lines+="- ${attachment}"$'\n'
      prompt_attachments+="- ${attachment}"$'\n'
    done
  fi

  cat > "$task_file" <<EOF
---
id: ${task_token}
project: ${project}
initiator: ${initiator_surface}
worker: ${worker_surface}
qa: ${qa_frontmatter}
signal: ${signal}
result: ${result_file}
---
# ${task_basename}

## Request
${instruction}

${attachment_lines}
EOF

  node "$KUMA_SERVER_CLI" dispatch-register \
    --task-file "$task_file" \
    --instruction "$instruction" \
    --summary "$instruction" \
    --initiator-label "$initiator_name" \
    --worker-id "$member_id" \
    --worker-name "$member_name" \
    --worker-type "$member_type" \
    --qa-member "$qa_member" \
    --qa-surface "$qa_surface" \
    --daemon-url "$KUMA_DAEMON_URL" > /dev/null

  prompt_footer="$(cat <<EOF
${prompt_attachments}${prompt_result}
Tracked task file: ${task_file}
Continue in-thread with:
- ~/.kuma/bin/kuma-dispatch ask --task-file ${task_file} --message "..."
- ~/.kuma/bin/kuma-dispatch reply --task-file ${task_file} --message "..."
Finish with:
- ~/.kuma/bin/kuma-dispatch done --task-file ${task_file} --summary "..."
- ~/.kuma/bin/kuma-dispatch fail --task-file ${task_file} --blocker "..."
EOF
)"

  send_dispatch_prompt \
    "$worker_surface" \
    "$task_token" \
    "$(format_dispatch_party "$initiator_name" initiator "$initiator_surface")" \
    "$(format_dispatch_party "$member_name" worker "$worker_surface")" \
    "$(dispatch_message_kind_label instruction)" \
    "$(dispatch_body_source_label forwarded-summary)" \
    "$instruction" \
    "$prompt_footer"

  printf 'TASK_ID: %s\n' "$task_token"
  printf 'TASK_FILE: %s\n' "$task_file"
  [ -n "$result_file" ] && printf 'RESULT_FILE: %s\n' "$result_file"
  printf 'WORKER: %s (%s, %s)\n' "$member_name" "$worker_surface" "$member_type"
}

dispatch_role_label() {
  case "${1:-}" in
    initiator)
      printf 'initiator'
      ;;
    worker)
      printf 'worker'
      ;;
    qa)
      printf 'QA'
      ;;
    surface)
      printf 'surface peer'
      ;;
    *)
      printf 'participant'
      ;;
  esac
}

dispatch_message_kind_label() {
  case "${1:-}" in
    question)
      printf 'question'
      ;;
    answer)
      printf 'reply'
      ;;
    status)
      printf 'status update'
      ;;
    blocker)
      printf 'blocker'
      ;;
    note)
      printf 'note'
      ;;
    instruction)
      printf 'assigned task'
      ;;
    *)
      printf 'message'
      ;;
  esac
}

dispatch_body_source_label() {
  case "${1:-}" in
    forwarded-summary)
      printf 'forwarded/orchestrated summary'
      ;;
    lifecycle-event)
      printf 'dispatch lifecycle event'
      ;;
    *)
      printf 'direct thread message'
      ;;
  esac
}

format_dispatch_party() {
  local display_label="${1:-}"
  local role="${2:-}"
  local surface="${3:-}"
  local role_label
  local meta=""
  local rendered_surface=""

  role_label="$(dispatch_role_label "$role")"
  if [ -z "$display_label" ] && [ "$role" = "initiator" ]; then
    display_label="unknown initiator"
  fi
  if [ -z "$display_label" ] && [ "$role" = "surface" ]; then
    display_label="unknown peer"
  fi
  display_label="${display_label:-$role_label}"
  rendered_surface="$(display_surface_meta "$surface")"
  if [ "$display_label" != "$role_label" ]; then
    meta="$role_label"
  fi
  if [ -n "$meta" ] && [ -n "$rendered_surface" ]; then
    printf '%s (%s, %s)' "$display_label" "$meta" "$rendered_surface"
  elif [ -n "$meta" ]; then
    printf '%s (%s)' "$display_label" "$meta"
  elif [ -n "$rendered_surface" ]; then
    printf '%s (%s)' "$display_label" "$rendered_surface"
  else
    printf '%s' "$display_label"
  fi
}

send_dispatch_prompt() {
  local surface="${1:?surface required}"
  local task_id="${2:?task id required}"
  local speaker_label="${3:?speaker label required}"
  local recipient_label="${4:?recipient label required}"
  local kind_label="${5:?kind label required}"
  local body_source_label="${6:?body source label required}"
  local message_text="${7:?message text required}"
  local footer="${8:-}"

  local prompt
  prompt="$(cat <<EOF
[Kuma Studio Dispatch] ${task_id}
Speaker: ${speaker_label}
Recipient: ${recipient_label}
Message kind: ${kind_label}
Body source: ${body_source_label}

${message_text}

${footer}
EOF
)"

  "$KUMA_CMUX_DIR/kuma-cmux-send.sh" "$surface" "$prompt"
}

append_lifecycle_trace_log() {
  local event_type="${1:-}"
  local task_id="${2:-}"
  local current_surface="${3:-}"
  local speaker_role="${4:-}"
  local speaker_surface="${5:-}"
  local speaker_label="${6:-}"
  local recipient_surface="${7:-}"
  local recipient_label="${8:-}"

  mkdir -p "$(dirname "$KUMA_LIFECYCLE_TRACE_LOG")"
  printf '%s LIFECYCLE_TRACE event=%s task=%s current_surface=%s speaker_role=%s speaker_surface=%s speaker_label="%s" recipient_surface=%s recipient_label="%s"\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "${event_type:-unknown}" \
    "${task_id:-unknown}" \
    "${current_surface:-unknown}" \
    "${speaker_role:-unknown}" \
    "${speaker_surface:-unknown}" \
    "${speaker_label:-}" \
    "${recipient_surface:-unknown}" \
    "${recipient_label:-}" >> "$KUMA_LIFECYCLE_TRACE_LOG"
}

infer_lifecycle_sender_role() {
  local event_type="${1:-}"
  local dispatch_json="${2:-}"
  local qa_surface=""

  case "$event_type" in
    complete|fail)
      printf 'worker\n'
      return 0
      ;;
    qa-pass|qa-reject)
      qa_surface="$(printf '%s' "$dispatch_json" | json_field dispatch.qaSurface)"
      if [ -n "$qa_surface" ]; then
        printf 'qa\n'
      else
        printf 'worker\n'
      fi
      return 0
      ;;
    *)
      printf 'surface\n'
      return 0
      ;;
  esac
}

resolve_dispatch_message_context() {
  local current_surface="${1:?current surface required}"
  local target="${2:-auto}"
  local kind="${3:-note}"
  local explicit_from="${4:-}"
  local explicit_from_surface="${5:-}"

  node -e '
const fs = require("node:fs");

const [, currentSurfaceRaw, targetRaw, kindRaw, explicitFromRaw, explicitFromSurfaceRaw] = process.argv;
const currentSurface = typeof currentSurfaceRaw === "string" ? currentSurfaceRaw.trim() : "";
const target = typeof targetRaw === "string" ? targetRaw.trim() : "auto";
const kind = typeof kindRaw === "string" ? kindRaw.trim() : "";
const explicitFrom = typeof explicitFromRaw === "string" ? explicitFromRaw.trim() : "";
const explicitFromSurface = typeof explicitFromSurfaceRaw === "string" ? explicitFromSurfaceRaw.trim() : "";
const payload = JSON.parse(fs.readFileSync(0, "utf8"));
const dispatch = payload?.dispatch ?? payload ?? {};

function normalize(value) {
  return typeof value === "string" ? value.trim() : "";
}

function normalizeRole(value) {
  const role = normalize(value);
  return role === "initiator" || role === "worker" || role === "qa" || role === "surface" ? role : "";
}

const initiator = normalize(dispatch.initiator);
const initiatorLabel = normalize(dispatch.initiatorLabel);
const worker = normalize(dispatch.worker);
const workerName = normalize(dispatch.workerName);
const qaSurface = normalize(dispatch.qaSurface) || (normalize(dispatch.qa).startsWith("surface:") ? normalize(dispatch.qa) : "");
const qaMember = normalize(dispatch.qaMember);
const projectId = normalize(dispatch.project);
const messages = Array.isArray(dispatch.messages) ? dispatch.messages : [];
const latestMessage = messages.length > 0 && typeof messages[messages.length - 1] === "object"
  ? messages[messages.length - 1]
  : null;
const registryPath = normalize(process.env.KUMA_SURFACES_PATH);

function parseRegistryLabel(label) {
  const text = normalize(label);
  const name = text.replace(/^[\p{Extended_Pictographic}\uFE0F\s]+/u, "").trim();
  return name || text;
}

function reverseLookupSurfaceLabel(surface) {
  if (!surface || !registryPath || !fs.existsSync(registryPath)) {
    return "";
  }

  try {
    const registry = JSON.parse(fs.readFileSync(registryPath, "utf8"));
    const projectOrder = projectId
      ? [projectId, ...Object.keys(registry).filter((key) => key !== projectId)]
      : Object.keys(registry);
    for (const candidateProject of projectOrder) {
      const entries = registry?.[candidateProject];
      if (!entries || typeof entries !== "object") {
        continue;
      }
      for (const [label, candidateSurface] of Object.entries(entries)) {
        if (normalize(candidateSurface) === surface) {
          return parseRegistryLabel(label);
        }
      }
    }
  } catch {}

  return "";
}

function rememberedLabelForRole(role, surface) {
  const targetSurface = normalize(surface);

  for (let index = messages.length - 1; index >= 0; index -= 1) {
    const message = messages[index];
    if (!message || typeof message !== "object") {
      continue;
    }

    const fromRole = normalizeRole(message.from);
    const toRole = normalizeRole(message.to);
    const fromLabel = normalize(message.fromLabel);
    const toLabel = normalize(message.toLabel);
    const fromSurface = normalize(message.fromSurface);
    const toSurface = normalize(message.toSurface);

    if (
      role === fromRole &&
      fromLabel &&
      (!targetSurface || !fromSurface || fromSurface === targetSurface)
    ) {
      return fromLabel;
    }

    if (
      role === toRole &&
      toLabel &&
      (!targetSurface || !toSurface || toSurface === targetSurface)
    ) {
      return toLabel;
    }
  }

  return "";
}

function labelForRole(role, surface) {
  if (role === "initiator") {
    return (
      initiatorLabel ||
      rememberedLabelForRole(role, surface || initiator) ||
      reverseLookupSurfaceLabel(surface || initiator)
    );
  }
  if (role === "worker") {
    return (
      workerName ||
      rememberedLabelForRole(role, surface || worker) ||
      reverseLookupSurfaceLabel(surface || worker)
    );
  }
  if (role === "qa") {
    return (
      qaMember ||
      rememberedLabelForRole(role, surface || qaSurface) ||
      reverseLookupSurfaceLabel(surface || qaSurface)
    );
  }
  return rememberedLabelForRole(role, surface) || reverseLookupSurfaceLabel(surface);
}

function surfaceForRole(role) {
  if (role === "initiator") return initiator;
  if (role === "worker") return worker;
  if (role === "qa") return qaSurface;
  return "";
}

let from = "initiator";
let fromSurface = initiator || currentSurface;
if (normalizeRole(explicitFrom)) {
  from = normalizeRole(explicitFrom);
  fromSurface = explicitFromSurface || surfaceForRole(from) || currentSurface || initiator;
} else if (currentSurface && currentSurface === worker) {
  from = "worker";
  fromSurface = worker;
} else if (currentSurface && currentSurface === qaSurface) {
  from = "qa";
  fromSurface = qaSurface;
} else if (currentSurface && currentSurface === initiator) {
  from = "initiator";
  fromSurface = initiator;
} else if (currentSurface && currentSurface !== initiator) {
  from = "surface";
  fromSurface = currentSurface;
}

let to = target || "auto";
let toSurface = "";
if (to === "auto" && kind === "answer" && from === "surface" && latestMessage) {
  const replyFrom = normalizeRole(latestMessage.to) || "surface";
  const replyTo = normalizeRole(latestMessage.from) || "surface";
  const replyFromSurface = normalize(latestMessage.toSurface) || surfaceForRole(replyFrom) || currentSurface;
  const replyToSurface = normalize(latestMessage.fromSurface) || surfaceForRole(replyTo);

  if (replyToSurface) {
    from = replyFrom;
    fromSurface = replyFromSurface;
    to = replyTo;
    toSurface = replyToSurface;
  }
}

if (to === "auto") {
  if (from === "worker") {
    to = "initiator";
    toSurface = initiator;
  } else if (from === "qa") {
    to = "worker";
    toSurface = worker;
  } else {
    to = "worker";
    toSurface = worker;
  }
} else if (to === "initiator") {
  toSurface = initiator;
} else if (to === "worker") {
  toSurface = worker;
} else if (to === "qa") {
  toSurface = qaSurface;
} else if (to.startsWith("surface:")) {
  toSurface = to;
  to = "surface";
}

const fromLabel = labelForRole(from, fromSurface);
const toLabel = labelForRole(to, toSurface);

process.stdout.write(`${JSON.stringify({
  taskId: normalize(dispatch.taskId),
  taskFile: normalize(dispatch.taskFile),
  from,
  fromLabel,
  fromSurface,
  to,
  toLabel,
  toSurface,
}, null, 2)}\n`);
' "$current_surface" "$target" "$kind" "$explicit_from" "$explicit_from_surface"
}

send_thread_message() {
  local kind="${1:?kind required}"
  shift

  local task_file=""
  local message_text=""
  local target="auto"
  local source="kuma-dispatch"
  local body_source="direct-message"
  local explicit_from=""
  local explicit_from_surface=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --kind)
        kind="${2:?message kind required}"
        shift 2
        ;;
      --task-file)
        task_file="${2:?task file required}"
        shift 2
        ;;
      --message|--text)
        message_text="${2:?message required}"
        shift 2
        ;;
      --to)
        target="${2:?target required}"
        shift 2
        ;;
      --from)
        explicit_from="${2:?from role required}"
        shift 2
        ;;
      --from-surface)
        explicit_from_surface="${2:?from surface required}"
        shift 2
        ;;
      --source)
        source="${2:?source required}"
        shift 2
        ;;
      --body-source)
        body_source="${2:?body source required}"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  [ -n "$task_file" ] || die "--task-file is required"
  [ -n "$message_text" ] || die "--message is required"

  ensure_runtime_requirements
  require_file "$KUMA_CMUX_DIR/kuma-cmux-send.sh"

  local current_surface
  current_surface="$(resolve_dispatch_sender_surface)"

  local dispatch_json
  dispatch_json="$(node "$KUMA_SERVER_CLI" dispatch-status \
    --task-file "$task_file" \
    --daemon-url "$KUMA_DAEMON_URL")"

  local context_json
  context_json="$(printf '%s' "$dispatch_json" | resolve_dispatch_message_context "$current_surface" "$target" "$kind" "$explicit_from" "$explicit_from_surface")"

  local task_id
  local from_role
  local from_label
  local from_surface
  local to_role
  local to_label
  local to_surface
  local project_id
  task_id="$(printf '%s' "$context_json" | json_field taskId)"
  from_role="$(printf '%s' "$context_json" | json_field from)"
  from_label="$(printf '%s' "$context_json" | json_field fromLabel)"
  from_surface="$(printf '%s' "$context_json" | json_field fromSurface)"
  to_role="$(printf '%s' "$context_json" | json_field to)"
  to_label="$(printf '%s' "$context_json" | json_field toLabel)"
  to_surface="$(printf '%s' "$context_json" | json_field toSurface)"
  project_id="$(printf '%s' "$dispatch_json" | json_field dispatch.project)"

  [ -n "$task_id" ] || die "dispatch not found for task file: $task_file"
  [ -n "$to_surface" ] || die "could not resolve a target surface for '$target'"

  if [ -z "$from_label" ]; then
    from_label="$(resolve_dispatch_party_display_name "$from_role" "$from_surface" "$project_id")"
  fi
  if [ -z "$to_label" ]; then
    to_label="$(resolve_dispatch_party_display_name "$to_role" "$to_surface" "$project_id")"
  fi

  node "$KUMA_SERVER_CLI" dispatch-message \
    --task-file "$task_file" \
    --kind "$kind" \
    --text "$message_text" \
    --body-source "$body_source" \
    --from "$from_role" \
    --to "$to_role" \
    --from-label "$from_label" \
    --to-label "$to_label" \
    --from-surface "$from_surface" \
    --to-surface "$to_surface" \
    --source "$source" \
    --daemon-url "$KUMA_DAEMON_URL" > /dev/null

  local speaker_label
  local recipient_label
  local kind_label
  local body_source_label
  speaker_label="$(format_dispatch_party "$from_label" "$from_role" "$from_surface")"
  recipient_label="$(format_dispatch_party "$to_label" "$to_role" "$to_surface")"
  kind_label="$(dispatch_message_kind_label "$kind")"
  body_source_label="$(dispatch_body_source_label "$body_source")"

  send_dispatch_prompt \
    "$to_surface" \
    "$task_id" \
    "$speaker_label" \
    "$recipient_label" \
    "$kind_label" \
    "$body_source_label" \
    "$message_text" \
    "Tracked task file: ${task_file}
Continue in-thread with:
- ~/.kuma/bin/kuma-dispatch ask --task-file ${task_file} --message \"...\"
- ~/.kuma/bin/kuma-dispatch reply --task-file ${task_file} --message \"...\""

  printf 'TASK_FILE: %s\n' "$task_file"
  printf 'TASK_ID: %s\n' "$task_id"
  printf 'FROM: %s (%s)\n' "$from_role" "$from_surface"
  printf 'TO: %s (%s)\n' "$to_role" "$to_surface"
}

dispatch_event_kind() {
  case "${1:-}" in
    fail|qa-reject)
      printf 'blocker'
      ;;
    *)
      printf 'status'
      ;;
  esac
}

format_lifecycle_notice() {
  local dispatch_json="${1:?dispatch json required}"

  printf '%s' "$dispatch_json" | node -e '
    const fs = require("node:fs");
    const payload = JSON.parse(fs.readFileSync(0, "utf8"));
    const dispatch = payload?.dispatch ?? payload ?? {};

    const normalize = (value) => (typeof value === "string" ? value.trim() : "");
    const status = normalize(dispatch.status);
    const lastEvent = normalize(dispatch.lastEvent);
    const workerName = normalize(dispatch.workerName) || "Worker";
    const qaMember = normalize(dispatch.qaMember) || "QA";
    const blocker = normalize(dispatch.blocker) || normalize(dispatch.note);

    let text = "";
    if (status === "worker-done") {
      text = `${workerName} reported worker completion. QA handoff target: ${qaMember}. Read the result file and continue QA handoff.`;
    } else if (status === "qa-passed" && lastEvent === "complete") {
      text = `${workerName} completed work and broker recorded direct completion. Read the result file for the final report.`;
    } else if (status === "qa-passed") {
      text = `${qaMember} passed QA. Read the result file for the final report.`;
    } else if (status === "qa-rejected") {
      text = blocker
        ? `${qaMember} rejected QA: ${blocker}. Read the result file and decide next action.`
        : `${qaMember} rejected QA. Read the result file and decide next action.`;
    } else if (status === "failed") {
      text = blocker
        ? `${workerName} reported a blocker: ${blocker}. Read the result file and decide next action.`
        : `${workerName} reported a blocker. Read the result file and decide next action.`;
    } else {
      text = `${workerName} reported lifecycle status ${status || "unknown"}. Read the result file and broker status.`;
    }

    process.stdout.write(`${text}\n`);
  '
}

emit_lifecycle_event_to_initiator() {
  local event_type="${1:?event type required}"
  local dispatch_json="${2:?dispatch json required}"

  if [ ! -f "$KUMA_CMUX_DIR/kuma-cmux-send.sh" ]; then
    printf 'LIFECYCLE_NOTICE_WARN: missing send wrapper %s\n' "$KUMA_CMUX_DIR/kuma-cmux-send.sh" >&2
    return 0
  fi

  local current_surface
  local kind
  local context_json
  local explicit_from_role
  local task_id
  local task_file
  local result_file
  local broker_status
  local from_role
  local from_label
  local from_surface
  local to_role
  local to_label
  local to_surface
  local project_id
  local speaker_label
  local recipient_label
  local kind_label
  local body_source_label
  local message_text

  current_surface="$(resolve_dispatch_sender_surface)"
  kind="$(dispatch_event_kind "$event_type")"
  explicit_from_role="$(infer_lifecycle_sender_role "$event_type" "$dispatch_json")"
  context_json="$(printf '%s' "$dispatch_json" | resolve_dispatch_message_context "$current_surface" "initiator" "$kind" "$explicit_from_role")"

  task_id="$(printf '%s' "$context_json" | json_field taskId)"
  task_file="$(printf '%s' "$dispatch_json" | json_field dispatch.taskFile)"
  result_file="$(printf '%s' "$dispatch_json" | json_field dispatch.resultFile)"
  broker_status="$(printf '%s' "$dispatch_json" | json_field dispatch.status)"
  from_role="$(printf '%s' "$context_json" | json_field from)"
  from_label="$(printf '%s' "$context_json" | json_field fromLabel)"
  from_surface="$(printf '%s' "$context_json" | json_field fromSurface)"
  to_role="$(printf '%s' "$context_json" | json_field to)"
  to_label="$(printf '%s' "$context_json" | json_field toLabel)"
  to_surface="$(printf '%s' "$context_json" | json_field toSurface)"
  project_id="$(printf '%s' "$dispatch_json" | json_field dispatch.project)"

  [ -n "$task_id" ] || return 0
  [ -n "$to_surface" ] || return 0

  if [ -z "$from_label" ]; then
    from_label="$(resolve_dispatch_party_display_name "$from_role" "$from_surface" "$project_id")"
  fi
  if [ -z "$to_label" ]; then
    to_label="$(resolve_dispatch_party_display_name "$to_role" "$to_surface" "$project_id")"
  fi

  speaker_label="$(format_dispatch_party "$from_label" "$from_role" "$from_surface")"
  recipient_label="$(format_dispatch_party "$to_label" "$to_role" "$to_surface")"
  kind_label="$(dispatch_message_kind_label "$kind")"
  body_source_label="$(dispatch_body_source_label lifecycle-event)"
  message_text="$(format_lifecycle_notice "$dispatch_json")"
  append_lifecycle_trace_log \
    "$event_type" \
    "$task_id" \
    "$current_surface" \
    "$from_role" \
    "$from_surface" \
    "$from_label" \
    "$to_surface" \
    "$to_label"

  send_dispatch_prompt \
    "$to_surface" \
    "$task_id" \
    "$speaker_label" \
    "$recipient_label" \
    "$kind_label" \
    "$body_source_label" \
    "$message_text" \
    "Tracked task file: ${task_file}
Result file: ${result_file:-n/a}
Broker status: ${broker_status:-unknown}
Primary completion authority: broker status + result file"
}

run_dispatch_event() {
  local event_type="${1:?event type required}"
  shift

  local dispatch_json=""
  local applied=""
  local ignored_reason=""
  dispatch_json="$(node "$KUMA_SERVER_CLI" "dispatch-${event_type}" "$@")"
  applied="$(printf '%s' "$dispatch_json" | node -e '
    const fs = require("node:fs");
    const payload = JSON.parse(fs.readFileSync(0, "utf8"));
    process.stdout.write(payload?.applied === false ? "false\n" : "true\n");
  ')"
  ignored_reason="$(printf '%s' "$dispatch_json" | node -e '
    const fs = require("node:fs");
    const payload = JSON.parse(fs.readFileSync(0, "utf8"));
    const value = typeof payload?.ignoredReason === "string" ? payload.ignoredReason.trim() : "";
    process.stdout.write(`${value}\n`);
  ')"
  if [ "$applied" = "true" ]; then
    emit_lifecycle_event_to_initiator "$event_type" "$dispatch_json"
  else
    printf 'LIFECYCLE_NOTICE_SKIP: event=%s reason=%s\n' "$event_type" "${ignored_reason:-ignored}" >&2
  fi
  printf '%s\n' "$dispatch_json"
}

case "$COMMAND" in
  assign)
    run_assign "$@"
    ;;
  send)
    run_assign "$@"
    ;;
  ask)
    send_thread_message question "$@"
    ;;
  reply)
    send_thread_message answer "$@"
    ;;
  message)
    send_thread_message note "$@"
    ;;
  done)
    run_dispatch_event complete "$@"
    ;;
  complete)
    run_dispatch_event complete "$@"
    ;;
  fail)
    run_dispatch_event fail "$@"
    ;;
  qa-pass)
    run_dispatch_event qa-pass "$@"
    ;;
  qa-reject)
    run_dispatch_event qa-reject "$@"
    ;;
  status)
    exec node "$KUMA_SERVER_CLI" dispatch-status "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    printf 'ERROR: unknown kuma-dispatch command: %s\n' "$COMMAND" >&2
    usage >&2
    exit 1
    ;;
esac
