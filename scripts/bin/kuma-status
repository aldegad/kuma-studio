#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/kuma-cli-common.sh"

usage() {
  cat <<'EOF'
Usage: kuma-status [--project <프로젝트>]
EOF
}

PROJECT_FILTER=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT_FILTER="${2:?project required}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

ensure_runtime_requirements

SNAPSHOT_JSON="$(read_team_status_snapshot_json "$PROJECT_FILTER")"

printf 'PROJECT\tMEMBER\tSURFACE\tSTATUS\tPREVIEW\n'

printf '%s' "$SNAPSHOT_JSON" | node -e '
  const fs = require("node:fs");
  const snapshot = JSON.parse(fs.readFileSync(0, "utf8"));
  const teamPath = process.argv[1];
  const team = JSON.parse(fs.readFileSync(teamPath, "utf8"));
  const teams = team?.teams ?? {};
  const byId = new Map();

  for (const [teamId, teamEntry] of Object.entries(teams)) {
    const members = Array.isArray(teamEntry?.members) ? teamEntry.members : [];
    for (const member of members) {
      if (member && typeof member.id === "string") {
        byId.set(member.id, {
          name: member.name ?? member.displayName ?? member.id,
          emoji: member.emoji ?? "",
          teamId,
        });
      }
    }
  }

  const projects = Array.isArray(snapshot?.projects) ? snapshot.projects : [];
  for (const project of projects) {
    const projectId = typeof project?.projectId === "string" ? project.projectId : "";
    const members = Array.isArray(project?.members) ? project.members : [];
    for (const member of members) {
      const id = typeof member?.id === "string" ? member.id : "";
      const surface = typeof member?.surface === "string" && member.surface.trim() ? member.surface : "-";
      if (!id) continue;

      const meta = byId.get(id) ?? { name: id, emoji: "", teamId: "" };
      const state =
        typeof member?.state === "string" && member.state.trim()
          ? member.state
          : surface === "-"
            ? "offline"
            : "idle";
      const preview =
        (typeof member?.task === "string" && member.task.trim()) ||
        (Array.isArray(member?.lastOutputLines) && typeof member.lastOutputLines[0] === "string" ? member.lastOutputLines[0] : "") ||
        "";
      const safePreview = String(preview).replace(/\t/g, " ").replace(/\r?\n/g, " ").trim();
      const label = meta.emoji ? `${meta.emoji} ${meta.name}` : meta.name;
      process.stdout.write(`${projectId}\t${label}\t${surface}\t${state}\t${safePreview}\n`);
    }
  }
' "$KUMA_TEAM_JSON_PATH"
